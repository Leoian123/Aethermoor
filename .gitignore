# =============================================
# .gitignore - Astro + Python 3.12 + LLM Project
# =============================================

# ------------------------------
# Environment & Secrets
# ------------------------------
.env
.env.*
.env.local
.env.development
.env.production
*.env
secrets/
config/secrets.yaml
config/secrets.json

# API Keys & Credentials (LLM)
.openai
.anthropic
.api_keys
credentials.json
service-account*.json

# ------------------------------
# Python
# ------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
.venv/
env/
ENV/
.python-version

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
**/site-packages/
venv/lib/
.venv/lib/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytest_cache/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff / Linting
.ruff_cache/

# Jupyter Notebook
.ipynb_checkpoints/

# pytype
.pytype/

# Cython debug symbols
cython_debug/

# Poetry
poetry.lock

# PDM
.pdm.toml
__pypackages__/

# uv (Python package manager)
uv.lock

# ------------------------------
# Node.js / Astro
# ------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Astro build output
dist/
.astro/

# Vite
*.local

# ------------------------------
# IDE & Editors
# ------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/
*.code-workspace

# ------------------------------
# OS Files
# ------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ------------------------------
# Logs & Debug
# ------------------------------
logs/
*.log
debug.log
error.log

# ------------------------------
# LLM Specific
# ------------------------------
# Model files (too large for git)
*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.onnx
models/
llm_models/

# LLM cache & embeddings
.langchain/
.llama_index/
chroma_db/
vector_store/
embeddings/
.cache/

# Prompt templates (if sensitive)
# prompts/private/

# Response logs (may contain sensitive data)
llm_logs/
response_cache/

# ------------------------------
# Database
# ------------------------------
*.db
*.sqlite
*.sqlite3
data/*.json
data/*.csv

# ------------------------------
# Docker
# ------------------------------
.docker/

# ------------------------------
# Misc
# ------------------------------
*.bak
*.tmp
*.temp
.scratch/
tmp/
temp/