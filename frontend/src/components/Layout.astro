---
// Layout.astro - Wrapper comune per tutte le pagine
export interface Props {
  title?: string;
}

const { title = 'STATISFY RPG' } = Astro.props;
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="stylesheet" href="/src/styles/global.css">
</head>
<body>
  <slot />
</body>
</html>
