---
// CharacterSlot.astro - Slot singolo personaggio nella dashboard
export interface Props {
  slot: number;
  name?: string;
  characterClass?: string;
  level?: number;
  exists?: boolean;
}

const { 
  slot, 
  name = null, 
  characterClass = null, 
  level = 1,
  exists = false 
} = Astro.props;
---

<div class="character-slot" data-slot={slot} data-exists={exists}>
  <div class="slot__portrait">
    {exists ? (
      <img src="/placeholder-portrait.png" alt={name} class="slot__image" />
    ) : (
      <div class="slot__empty">
        <svg viewBox="0 0 24 24" width="48" height="48" stroke="currentColor" stroke-width="1" fill="none">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
      </div>
    )}
  </div>
  
  <div class="slot__info">
    {exists ? (
      <>
        <span class="slot__name">{name}</span>
        <span class="slot__class">{characterClass} · Lv.{level}</span>
      </>
    ) : (
      <span class="slot__new">Nuovo Personaggio</span>
    )}
  </div>
  
  {exists && (
    <button class="slot__delete" data-slot={slot} title="Elimina personaggio">
      <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
        <polyline points="3 6 5 6 21 6"></polyline>
        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
      </svg>
    </button>
  )}
</div>

<style>
  .character-slot {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-lg);
    background: var(--abyss);
    border: 2px solid var(--mist);
    border-radius: 12px;
    cursor: pointer;
    transition: var(--transition-smooth);
  }
  
  .character-slot:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }
  
  .character-slot[data-exists="true"]:hover {
    background: var(--shadow);
  }
  
  .slot__portrait {
    width: 120px;
    height: 120px;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: var(--space-md);
    background: var(--shadow);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .slot__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .slot__empty {
    color: var(--smoke);
    transition: var(--transition-smooth);
  }
  
  .character-slot:hover .slot__empty {
    color: var(--accent);
  }
  
  .slot__info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    text-align: center;
  }
  
  .slot__name {
    font-family: var(--font-narrative);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--parchment);
  }
  
  .slot__class {
    font-size: 0.8rem;
    color: var(--ash);
  }
  
  .slot__new {
    font-size: 0.9rem;
    color: var(--smoke);
    transition: var(--transition-smooth);
  }
  
  .character-slot:hover .slot__new {
    color: var(--accent);
  }
  
  .slot__delete {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--void);
    border: 1px solid var(--mist);
    border-radius: 4px;
    color: var(--smoke);
    cursor: pointer;
    opacity: 0;
    transition: var(--transition-fast);
  }
  
  .character-slot:hover .slot__delete {
    opacity: 1;
  }
  
  .slot__delete:hover {
    background: var(--tempus);
    border-color: var(--tempus);
    color: var(--parchment);
  }
</style>
