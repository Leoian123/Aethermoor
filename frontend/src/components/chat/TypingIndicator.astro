---
// TypingIndicator.astro - Indicatore con messaggi RPG rotanti
---

<div class="typing-indicator" id="typing-indicator">
  <span class="typing-indicator__text" id="typing-text"></span>
  <span class="typing-indicator__dots">
    <span></span>
    <span></span>
    <span></span>
  </span>
</div>

<script>
  const LOADING_MESSAGES = [
    "Pulendo i draghi",
    "Cambiando il thé del Re di Valeria",
    "Affilando spade tileane",
    "Consultando il Grimorio Antico",
    "Svegliando il Progenitore di turno",
    "Negoziando con i goblin del sindacato",
    "Districando nodi nel tessuto arcano",
    "Lustrando l'armatura cerimoniale",
    "Interrogando le stelle",
    "Preparando pozioni improbabili",
    "Convincendo un mimic a non essere una cassa",
    "Ricalcolando le orbite delle lune",
    "Cercando la chiave giusta tra 47 chiavi",
    "Srotolando una pergamena infinita",
    "Dando da mangiare al famiglio",
    "Smistando le lamentele degli spiriti",
    "Lucidando sfere di cristallo",
    "Insegnando al bardo una rima nuova",
    "Contando le scaglie del drago contabile",
    "Riparando il teletrasporto del mago pigro",
  ];

  let rotateInterval = null;
  const textEl = document.getElementById('typing-text');
  const indicator = document.getElementById('typing-indicator');

  function pickRandom() {
    return LOADING_MESSAGES[Math.floor(Math.random() * LOADING_MESSAGES.length)];
  }

  function startRotation() {
    if (textEl) textEl.textContent = pickRandom();
    rotateInterval = setInterval(() => {
      if (textEl) textEl.textContent = pickRandom();
    }, 3000);
  }

  function stopRotation() {
    if (rotateInterval) {
      clearInterval(rotateInterval);
      rotateInterval = null;
    }
  }

  // Osserva il cambio della classe .active
  const observer = new MutationObserver(() => {
    if (indicator?.classList.contains('active')) {
      startRotation();
    } else {
      stopRotation();
    }
  });

  if (indicator) {
    observer.observe(indicator, { attributes: true, attributeFilter: ['class'] });
  }
</script>

<style>
  .typing-indicator {
    display: none;
    align-items: center;
    gap: 8px;
    padding: var(--space-sm) var(--space-md);
    align-self: flex-start;
    font-style: italic;
    color: var(--smoke);
    font-size: 0.9rem;
    max-width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .typing-indicator__text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .typing-indicator.active {
    display: flex;
  }

  .typing-indicator__dots {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .typing-indicator__dots span {
    width: 6px;
    height: 6px;
    background: var(--smoke);
    border-radius: 50%;
    animation: typingBounce 1.4s infinite ease-in-out;
  }

  .typing-indicator__dots span:nth-child(1) { animation-delay: 0s; }
  .typing-indicator__dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator__dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typingBounce {
    0%, 80%, 100% {
      transform: scale(0.8);
      opacity: 0.5;
    }
    40% {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>
