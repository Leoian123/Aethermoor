---
// ChatMessage.astro - Singolo messaggio nella chat
export interface Props {
  sender: 'user' | 'ai';
  content: string;
}

const { sender, content } = Astro.props;
const isUser = sender === 'user';
---

<div class={`message message--${sender}`}>
  <div class="message__label">{isUser ? 'Tu' : 'Game Master'}</div>
  <div class="message__content" set:html={content} />
</div>

<style>
  .message {
    max-width: 85%;
    animation: messageIn 0.3s ease-out;
  }
  
  @keyframes messageIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .message--user {
    align-self: flex-end;
  }
  
  .message--ai {
    align-self: flex-start;
  }
  
  .message__label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--smoke);
    margin-bottom: var(--space-xs);
    padding-left: var(--space-sm);
  }
  
  .message--user .message__label {
    text-align: right;
    padding-right: var(--space-sm);
    padding-left: 0;
  }
  
  .message__content {
    padding: var(--space-md) var(--space-lg);
    border-radius: 12px;
    line-height: 1.7;
  }
  
  .message--user .message__content {
    background: linear-gradient(135deg, var(--accent-dim) 0%, var(--shadow) 100%);
    border: 1px solid var(--accent);
    border-bottom-right-radius: 4px;
    font-family: var(--font-ui);
    font-size: 0.95rem;
  }
  
  .message--ai .message__content {
    background: var(--shadow);
    border: 1px solid var(--mist);
    border-bottom-left-radius: 4px;
    font-family: var(--font-narrative);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--parchment);
  }
  
  /* Tag meccanici inline */
  .message__content :global(.tag) {
    display: inline;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-style: normal;
    background: var(--void);
    color: var(--accent);
    padding: 2px 6px;
    border-radius: 3px;
    margin: 0 2px;
    border: 1px solid var(--mist);
  }
</style>
