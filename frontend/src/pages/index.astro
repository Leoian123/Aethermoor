---
// index.astro - Redirect iniziale
// Se autenticato → /home, altrimenti → /login
---

<html lang="it">
<head>
  <meta charset="UTF-8">
  <title>STATISFY RPG</title>
</head>
<body>
  <script>
    import { isAuthenticated } from '../lib/auth.js';

    if (isAuthenticated()) {
      window.location.replace('/home');
    } else {
      window.location.replace('/login');
    }
  </script>
</body>
</html>
