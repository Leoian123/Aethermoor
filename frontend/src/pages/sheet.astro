---
// sheet.astro - Scheda personaggio con drag & drop equipment
import Layout from '../components/Layout.astro';
import Header from '../components/ui/Header.astro';
---

<Layout title="STATISFY RPG - Scheda">
  <div class="sheet-page">
    <Header showBackButton />
    
    <main class="sheet-main">
      <!-- Header personaggio -->
      <section class="char-header">
        <div class="char-portrait">
          <div class="portrait-placeholder">?</div>
          <span class="char-level" id="char-level">1</span>
        </div>
        <div class="char-info">
          <h1 class="char-name" id="char-name">—</h1>
          <span class="char-class" id="char-class">—</span>
          <div class="char-bars">
            <div class="resource-bar hp-bar">
              <div class="bar-fill" id="hp-bar"></div>
              <span class="bar-text"><span id="hp-current">0</span>/<span id="hp-max">0</span></span>
            </div>
            <div class="resource-bar mana-bar">
              <div class="bar-fill" id="mana-bar"></div>
              <span class="bar-text"><span id="mana-current">0</span>/<span id="mana-max">0</span></span>
            </div>
          </div>
        </div>
      </section>
      
      <!-- Tabs -->
      <nav class="tabs">
        <button class="tab active" data-tab="stats">📊 Statistiche</button>
        <button class="tab" data-tab="skills">⚔️ Abilità</button>
        <button class="tab" data-tab="equipment">🎒 Equipaggiamento</button>
      </nav>
      
      <!-- Panel: Statistiche -->
      <section class="panel active" id="panel-stats">
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-header"><span class="stat-icon">💪</span><span>Forza</span></div>
            <div class="stat-values">
              <span class="stat-base" id="base-str">10</span>
              <span class="stat-mod" id="mod-str"></span>
              <span class="stat-total" id="total-str">10</span>
            </div>
            <div class="stat-desc">Danno fisico, capacità di carico</div>
          </div>
          <div class="stat-card">
            <div class="stat-header"><span class="stat-icon">⚡</span><span>Destrezza</span></div>
            <div class="stat-values">
              <span class="stat-base" id="base-dex">10</span>
              <span class="stat-mod" id="mod-dex"></span>
              <span class="stat-total" id="total-dex">10</span>
            </div>
            <div class="stat-desc">Evasione, precisione, iniziativa</div>
          </div>
          <div class="stat-card">
            <div class="stat-header"><span class="stat-icon">❤️</span><span>Vitalità</span></div>
            <div class="stat-values">
              <span class="stat-base" id="base-vit">10</span>
              <span class="stat-mod" id="mod-vit"></span>
              <span class="stat-total" id="total-vit">10</span>
            </div>
            <div class="stat-desc">Punti vita, resistenza fisica</div>
          </div>
          <div class="stat-card">
            <div class="stat-header"><span class="stat-icon">🧠</span><span>Intelligenza</span></div>
            <div class="stat-values">
              <span class="stat-base" id="base-int">10</span>
              <span class="stat-mod" id="mod-int"></span>
              <span class="stat-total" id="total-int">10</span>
            </div>
            <div class="stat-desc">Potere magico, mana massimo</div>
          </div>
        </div>
        
        <div class="derived-stats">
          <h3 class="section-label">Statistiche Derivate</h3>
          <div class="derived-grid">
            <div class="derived-item"><span class="derived-label">Danno Fisico</span><span class="derived-value" id="derived-phys">+0%</span></div>
            <div class="derived-item"><span class="derived-label">Potere Magico</span><span class="derived-value" id="derived-magic">+0%</span></div>
            <div class="derived-item"><span class="derived-label">Evasione</span><span class="derived-value" id="derived-eva">0%</span></div>
            <div class="derived-item"><span class="derived-label">Regen HP</span><span class="derived-value" id="derived-regen">0/turno</span></div>
          </div>
        </div>
      </section>
      
      <!-- Panel: Abilità -->
      <section class="panel" id="panel-skills">
        <div class="skills-section">
          <h3 class="section-label">Sfere Magiche</h3>
          <div class="skills-grid" id="skills-spheres"></div>
        </div>
        <div class="skills-section">
          <h3 class="section-label">Arti Marziali</h3>
          <div class="skills-grid" id="skills-martial"></div>
        </div>
        <div class="skills-section">
          <h3 class="section-label">Conoscenze</h3>
          <div class="skills-grid" id="skills-knowledge"></div>
        </div>
        <p class="empty-msg" id="skills-empty">Nessuna abilità appresa</p>
      </section>
      
      <!-- Panel: Equipaggiamento -->
      <section class="panel" id="panel-equipment">
        <div class="equip-layout">
          <!-- Equipment Slots -->
          <div class="equipment-side">
            <h3 class="section-label">Equipaggiamento</h3>
            <div class="equipment-slots">
              <div class="equip-slot" data-slot="main_hand">
                <span class="slot-label">Mano Principale</span>
                <div class="slot-drop-area" id="slot-main_hand"></div>
              </div>
              <div class="equip-slot" data-slot="off_hand">
                <span class="slot-label">Mano Secondaria</span>
                <div class="slot-drop-area" id="slot-off_hand"></div>
              </div>
              <div class="equip-slot" data-slot="two_hand">
                <span class="slot-label">Due Mani</span>
                <div class="slot-drop-area" id="slot-two_hand"></div>
              </div>
              <div class="equip-slot" data-slot="chest">
                <span class="slot-label">Armatura</span>
                <div class="slot-drop-area" id="slot-chest"></div>
              </div>
              <div class="equip-slot" data-slot="neck">
                <span class="slot-label">Collana</span>
                <div class="slot-drop-area" id="slot-neck"></div>
              </div>
              <div class="equip-slot" data-slot="belt">
                <span class="slot-label">Cintura</span>
                <div class="slot-drop-area" id="slot-belt"></div>
              </div>
            </div>
          </div>
          
          <!-- Inventario -->
          <div class="inventory-side">
            <h3 class="section-label">Inventario <small>(trascina sugli slot)</small></h3>
            <div class="inventory-drop-zone" id="inventory-drop-zone">
              <div class="inventory-grid" id="inventory-grid"></div>
              <p class="empty-msg" id="inv-empty">Inventario vuoto</p>
            </div>
          </div>
        </div>
      </section>
    </main>
    
    <!-- Tooltip -->
    <div class="tooltip" id="tooltip"></div>
  </div>
</Layout>

<script>
  import { getCharacterBySlot, equipItem as apiEquip, unequipItem as apiUnequip, moveEquipment as apiMove } from '../lib/api.js';
  
  let character = null;
  let draggedItem = null;
  const tooltip = document.getElementById('tooltip');
  
  const urlParams = new URLSearchParams(window.location.search);
  const slot = parseInt(urlParams.get('slot') || sessionStorage.getItem('currentSlot') || '0');
  sessionStorage.setItem('currentSlot', slot.toString());
  
  const SLOT_LABELS = {
    main_hand: 'Mano Principale',
    off_hand: 'Mano Secondaria', 
    two_hand: 'Due Mani',
    chest: 'Armatura',
    neck: 'Collana',
    belt: 'Cintura'
  };
  
  // ══════════════════════════════════════════════════════
  // INIT
  // ══════════════════════════════════════════════════════
  
  async function init() {
    try {
      const result = await getCharacterBySlot(slot);
      if (!result.exists) {
        window.location.href = '/';
        return;
      }
      character = result.character;
      render();
    } catch (e) {
      console.error('Errore:', e);
      window.location.href = '/';
    }
  }
  
  function render() {
    renderHeader();
    renderStats();
    renderSkills();
    renderEquipment();
    renderInventory();
  }
  
  // ══════════════════════════════════════════════════════
  // HEADER
  // ══════════════════════════════════════════════════════
  
  function renderHeader() {
    document.getElementById('char-name').textContent = character.name;
    document.getElementById('char-class').textContent = character.class?.name || '—';
    document.getElementById('char-level').textContent = character.level;
    
    document.getElementById('hp-current').textContent = character.hp_current;
    document.getElementById('hp-max').textContent = character.hp_max;
    document.getElementById('hp-bar').style.width = `${(character.hp_current / character.hp_max) * 100}%`;
    
    document.getElementById('mana-current').textContent = character.mana_current;
    document.getElementById('mana-max').textContent = character.mana_max;
    document.getElementById('mana-bar').style.width = `${(character.mana_current / character.mana_max) * 100}%`;
  }
  
  // ══════════════════════════════════════════════════════
  // STATS
  // ══════════════════════════════════════════════════════
  
  function renderStats() {
    const bonuses = calculateBonuses();
    
    ['str', 'dex', 'vit', 'int'].forEach(stat => {
      const base = character[stat] || 10;
      const bonus = bonuses[stat] || 0;
      
      document.getElementById(`base-${stat}`).textContent = base;
      document.getElementById(`total-${stat}`).textContent = base + bonus;
      
      const modEl = document.getElementById(`mod-${stat}`);
      if (bonus !== 0) {
        modEl.textContent = bonus > 0 ? `+${bonus}` : bonus;
        modEl.className = `stat-mod ${bonus > 0 ? 'buff' : 'debuff'}`;
      } else {
        modEl.textContent = '';
      }
    });
    
    const totalStr = (character.str || 10) + (bonuses.str || 0);
    const totalDex = (character.dex || 10) + (bonuses.dex || 0);
    const totalVit = (character.vit || 10) + (bonuses.vit || 0);
    const totalInt = (character.int || 10) + (bonuses.int || 0);
    
    document.getElementById('derived-phys').textContent = `+${totalStr}%`;
    document.getElementById('derived-magic').textContent = `+${Math.floor(totalInt * 1.25)}%`;
    document.getElementById('derived-eva').textContent = `${Math.floor(totalDex / 2)}%`;
    document.getElementById('derived-regen').textContent = `${Math.floor(totalVit / 10)}/turno`;
  }
  
  function calculateBonuses() {
    const bonuses = { str: 0, dex: 0, vit: 0, int: 0 };
    if (character.equipment) {
      character.equipment.forEach(item => {
        if (item.stats_bonus) {
          for (const [stat, val] of Object.entries(item.stats_bonus)) {
            if (bonuses[stat] !== undefined) bonuses[stat] += val;
          }
        }
      });
    }
    return bonuses;
  }
  
  // ══════════════════════════════════════════════════════
  // SKILLS
  // ══════════════════════════════════════════════════════
  
  function renderSkills() {
    if (!character.skills?.length) {
      document.getElementById('skills-empty').style.display = 'block';
      return;
    }
    document.getElementById('skills-empty').style.display = 'none';
    
    const spheres = character.skills.filter(s => s.category === 'sphere');
    const martial = character.skills.filter(s => s.category === 'martial');
    const knowledge = character.skills.filter(s => s.category === 'knowledge');
    
    document.getElementById('skills-spheres').innerHTML = spheres.map(createSkillCard).join('');
    document.getElementById('skills-martial').innerHTML = martial.map(createSkillCard).join('');
    document.getElementById('skills-knowledge').innerHTML = knowledge.map(createSkillCard).join('');
    
    document.querySelectorAll('.skill-card').forEach(card => {
      card.addEventListener('mouseenter', showSkillTooltip);
      card.addEventListener('mousemove', moveTooltip);
      card.addEventListener('mouseleave', hideTooltip);
    });
  }
  
  function createSkillCard(skill) {
    const color = getSkillColor(skill.tag);
    const icon = getSkillIcon(skill);
    return `
      <div class="skill-card ${skill.type}" style="--skill-color: ${color}" data-skill='${JSON.stringify(skill).replace(/'/g, "&#39;")}'>
        <div class="skill-icon-wrap">
          <span class="skill-icon">${icon}</span>
          <span class="skill-mastery">${skill.mastery}</span>
        </div>
        <div class="skill-info">
          <span class="skill-name">${skill.name}</span>
          <span class="skill-type-label">${skill.type === 'active' ? 'Attiva' : 'Passiva'}</span>
        </div>
      </div>
    `;
  }
  
  function getSkillIcon(skill) {
    const icons = { 'IGNIS': '🔥', 'AQUA': '💧', 'TERRA': '🪨', 'VENTUS': '💨', 'MENS': '🧿', 'ANIMA': '👻', 'VIS': '⚡', 'VITA': '💚', 'SPATIUM': '🌀', 'TEMPUS': '⏳', 'SWORD': '⚔️', 'DAGGER': '🗡️', 'SHIELD': '🛡️' };
    for (const [key, icon] of Object.entries(icons)) {
      if (skill.tag.includes(key)) return icon;
    }
    return '✨';
  }
  
  function getSkillColor(tag) {
    const colors = { 'IGNIS': '#ff6b35', 'AQUA': '#4ecdc4', 'TERRA': '#8b7355', 'VENTUS': '#a8d5e5', 'MENS': '#9b59b6', 'ANIMA': '#1abc9c', 'VIS': '#f1c40f', 'VITA': '#2ecc71', 'SPATIUM': '#3498db', 'TEMPUS': '#e74c3c', 'SWORD': '#e67e22', 'DAGGER': '#c0392b' };
    for (const [key, color] of Object.entries(colors)) {
      if (tag.includes(key)) return color;
    }
    return '#c9a959';
  }
  
  function showSkillTooltip(e) {
    const skill = JSON.parse(e.currentTarget.dataset.skill);
    tooltip.innerHTML = `
      <div class="tip-header">
        <span class="tip-name">${skill.name}</span>
        <span class="tip-type ${skill.type}">${skill.type === 'active' ? 'Attiva' : 'Passiva'}</span>
      </div>
      <p class="tip-desc">${skill.description}</p>
      <div class="tip-mastery">Maestria: ${skill.mastery}/10</div>
      ${skill.base_cost > 0 ? `<div class="tip-stat">💧 Costo: ${skill.base_cost} mana</div>` : ''}
      ${skill.cooldown > 0 ? `<div class="tip-stat">⏱️ Cooldown: ${skill.cooldown} turni</div>` : ''}
      <div class="tip-footer">${skill.tag}</div>
    `;
    tooltip.classList.add('visible');
    moveTooltip(e);
  }
  
  // ══════════════════════════════════════════════════════
  // EQUIPMENT
  // ══════════════════════════════════════════════════════
  
  function renderEquipment() {
    // Reset all slots
    document.querySelectorAll('.slot-drop-area').forEach(el => {
      el.innerHTML = '<span class="slot-empty">Vuoto</span>';
      el.parentElement.classList.remove('filled');
    });
    
    if (!character.equipment?.length) return;
    
    character.equipment.forEach(item => {
      const dropArea = document.getElementById(`slot-${item.equipped_slot}`);
      if (dropArea) {
        dropArea.innerHTML = createItemCard(item, true);
        dropArea.parentElement.classList.add('filled');
        
        const card = dropArea.querySelector('.item-card');
        setupItemCardEvents(card, item, true);
      }
    });
  }
  
  function renderInventory() {
    const grid = document.getElementById('inventory-grid');
    const empty = document.getElementById('inv-empty');
    
    if (!character.inventory?.length) {
      empty.style.display = 'block';
      grid.innerHTML = '';
      return;
    }
    
    empty.style.display = 'none';
    grid.innerHTML = character.inventory.map(item => createItemCard(item, false)).join('');
    
    document.querySelectorAll('#inventory-grid .item-card').forEach(card => {
      const item = JSON.parse(card.dataset.item);
      setupItemCardEvents(card, item, false);
    });
  }
  
  function createItemCard(item, equipped) {
    const rarity = item.rarity || 'common';
    const icon = getItemIcon(item.type);
    const tags = item.equip_tags || [];
    const tagsDisplay = tags.map(t => SLOT_LABELS[t] || t).join(', ');
    
    return `
      <div class="item-card ${rarity}" 
           draggable="true" 
           data-item='${JSON.stringify(item).replace(/'/g, "&#39;")}'
           data-equipped="${equipped}"
           data-equip-tags="${tags.join(',')}">
        <div class="item-icon">${icon}</div>
        <div class="item-details">
          <span class="item-name">${item.name || item.item_name}</span>
          <span class="item-type">${item.type || 'Oggetto'}</span>
        </div>
        ${item.quantity > 1 ? `<span class="item-qty">×${item.quantity}</span>` : ''}
      </div>
    `;
  }
  
  function getItemIcon(type) {
    const icons = { weapon: '⚔️', armor: '🛡️', shield: '🛡️', accessory: '💍', consumable: '🧪' };
    return icons[type] || '📦';
  }
  
  function setupItemCardEvents(card, item, equipped) {
    // Drag start
    card.addEventListener('dragstart', (e) => {
      draggedItem = { item, equipped, element: card };
      card.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
      
      // Highlight compatible slots (escludi slot corrente se equipaggiato)
      const tags = item.equip_tags || [];
      const currentSlot = equipped ? item.equipped_slot : null;
      
      document.querySelectorAll('.equip-slot').forEach(slot => {
        const slotId = slot.dataset.slot;
        if (tags.includes(slotId) && slotId !== currentSlot) {
          slot.classList.add('drop-valid');
        }
      });
      
      // Se è equipped, highlight anche inventario
      if (equipped) {
        document.getElementById('inventory-drop-zone').classList.add('drop-valid');
      }
    });
    
    card.addEventListener('dragend', () => {
      card.classList.remove('dragging');
      document.querySelectorAll('.drop-valid, .drop-over').forEach(el => {
        el.classList.remove('drop-valid', 'drop-over');
      });
      draggedItem = null;
    });
    
    // Tooltip
    card.addEventListener('mouseenter', showItemTooltip);
    card.addEventListener('mousemove', moveTooltip);
    card.addEventListener('mouseleave', hideTooltip);
  }
  
  function showItemTooltip(e) {
    const item = JSON.parse(e.currentTarget.dataset.item);
    const tags = item.equip_tags || [];
    const slotsText = tags.map(t => SLOT_LABELS[t] || t).join(', ');
    
    let bonusHtml = '';
    if (item.stats_bonus) {
      bonusHtml = Object.entries(item.stats_bonus)
        .map(([stat, val]) => `<div class="tip-stat bonus">+${val} ${stat.toUpperCase()}</div>`)
        .join('');
    }
    
    tooltip.innerHTML = `
      <div class="tip-header">
        <span class="tip-name">${item.name || item.item_name}</span>
        <span class="tip-rarity ${item.rarity || 'common'}">${item.rarity || 'common'}</span>
      </div>
      <div class="tip-item-type">${item.type || 'Oggetto'}</div>
      ${item.description ? `<p class="tip-desc">${item.description}</p>` : ''}
      ${bonusHtml}
      <div class="tip-slots">Slot: ${slotsText}</div>
    `;
    tooltip.classList.add('visible');
    moveTooltip(e);
  }
  
  // ══════════════════════════════════════════════════════
  // DRAG & DROP
  // ══════════════════════════════════════════════════════
  
  // Setup drop zones for equipment slots
  document.querySelectorAll('.slot-drop-area').forEach(dropArea => {
    const slotEl = dropArea.parentElement;
    const slotId = slotEl.dataset.slot;
    
    dropArea.addEventListener('dragover', (e) => {
      if (!draggedItem) return;
      const tags = draggedItem.item.equip_tags || [];
      const currentSlot = draggedItem.equipped ? draggedItem.item.equipped_slot : null;
      
      // Permetti drop solo su slot compatibili e diversi da quello corrente
      if (tags.includes(slotId) && slotId !== currentSlot) {
        e.preventDefault();
        slotEl.classList.add('drop-over');
      }
    });
    
    dropArea.addEventListener('dragleave', () => {
      slotEl.classList.remove('drop-over');
    });
    
    dropArea.addEventListener('drop', async (e) => {
      e.preventDefault();
      slotEl.classList.remove('drop-over');
      
      if (!draggedItem) return;
      const { item, equipped } = draggedItem;
      
      try {
        let result;
        if (equipped) {
          // Spostamento diretto tra slot
          result = await apiMove(character.id, item.equipped_slot, slotId);
        } else {
          // Equip da inventario
          result = await apiEquip(character.id, item.item_name, slotId);
        }
        
        if (result.success) {
          await refreshCharacter();
        }
      } catch (err) {
        console.error('Equip/Move error:', err);
      }
    });
  });
  
  // Setup drop zone for inventory (unequip)
  const invDropZone = document.getElementById('inventory-drop-zone');
  
  invDropZone.addEventListener('dragover', (e) => {
    if (draggedItem?.equipped) {
      e.preventDefault();
      invDropZone.classList.add('drop-over');
    }
  });
  
  invDropZone.addEventListener('dragleave', () => {
    invDropZone.classList.remove('drop-over');
  });
  
  invDropZone.addEventListener('drop', async (e) => {
    e.preventDefault();
    invDropZone.classList.remove('drop-over');
    
    if (!draggedItem?.equipped) return;
    
    try {
      const result = await apiUnequip(character.id, draggedItem.item.equipped_slot);
      if (result.success) {
        await refreshCharacter();
      }
    } catch (err) {
      console.error('Unequip error:', err);
    }
  });
  
  async function refreshCharacter() {
    const result = await getCharacterBySlot(slot);
    character = result.character;
    render();
  }
  
  // ══════════════════════════════════════════════════════
  // TOOLTIP
  // ══════════════════════════════════════════════════════
  
  function moveTooltip(e) {
    let x = e.clientX + 15;
    let y = e.clientY + 15;
    const rect = tooltip.getBoundingClientRect();
    if (x + 220 > window.innerWidth) x = e.clientX - 230;
    if (y + rect.height > window.innerHeight) y = e.clientY - rect.height - 15;
    tooltip.style.left = `${x}px`;
    tooltip.style.top = `${y}px`;
  }
  
  function hideTooltip() {
    tooltip.classList.remove('visible');
  }
  
  // ══════════════════════════════════════════════════════
  // TABS
  // ══════════════════════════════════════════════════════
  
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(`panel-${tab.dataset.tab}`).classList.add('active');
    });
  });
  
  init();
</script>

<style>
  .sheet-page {
    min-height: 100vh;
    max-width: 950px;
    margin: 0 auto;
    padding: var(--space-md);
  }
  
  .sheet-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  
  /* Header */
  .char-header {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-lg);
    background: linear-gradient(135deg, var(--abyss) 0%, var(--shadow) 100%);
    border: 1px solid var(--mist);
    border-radius: 12px;
  }
  
  .char-portrait {
    position: relative;
    width: 80px;
    height: 80px;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid var(--accent);
    flex-shrink: 0;
  }
  
  .portrait-placeholder {
    width: 100%;
    height: 100%;
    background: var(--shadow);
