---
// sheet.astro - Scheda personaggio con drag & drop equipment
import Layout from '../components/Layout.astro';
import Header from '../components/ui/Header.astro';
---

<Layout title="STATISFY RPG - Scheda">
  <div class="sheet-page">
    <Header showBackButton backHref="/characters" />
    
    <main class="sheet-main">
      <!-- Header personaggio -->
      <section class="char-header">
        <div class="char-portrait">
          <div class="portrait-placeholder">?</div>
          <span class="char-level" id="char-level">1</span>
        </div>
        <div class="char-info">
          <h1 class="char-name" id="char-name">—</h1>
          <span class="char-class" id="char-class">—</span>
          <div class="char-bars">
            <div class="resource-bar hp-bar">
              <div class="bar-fill" id="hp-bar"></div>
              <span class="bar-text"><span id="hp-current">0</span>/<span id="hp-max">0</span></span>
            </div>
            <div class="resource-bar mana-bar">
              <div class="bar-fill" id="mana-bar"></div>
              <span class="bar-text"><span id="mana-current">0</span>/<span id="mana-max">0</span></span>
            </div>
            <div class="resource-bar xp-bar">
              <div class="bar-fill" id="xp-bar"></div>
              <span class="bar-text">XP: <span id="xp-current">0</span>/<span id="xp-next">100</span></span>
            </div>
          </div>
          <div class="char-currency">
            <span class="currency-icon">🪙</span>
            <span class="currency-value" id="corone-display">0</span>
            <span class="currency-label">corone</span>
          </div>
        </div>
      </section>
      
      <!-- Tabs -->
      <nav class="tabs">
        <button class="tab active" data-tab="stats">📊 Statistiche</button>
        <button class="tab" data-tab="skills">⚔️ Abilità</button>
        <button class="tab" data-tab="equipment">🎒 Equipaggiamento</button>
        <button class="tab" data-tab="journal">📜 Diario</button>
      </nav>
      
      <!-- Panel: Statistiche -->
      <section class="panel active" id="panel-stats">
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-header"><span class="stat-icon">💪</span><span>Forza</span></div>
            <div class="stat-values">
              <span class="stat-base" id="base-str">10</span>
              <span class="stat-mod" id="mod-str"></span>
              <span class="stat-total" id="total-str">10</span>
            </div>
            <div class="stat-desc">Danno fisico, capacità di carico</div>
          </div>
          <div class="stat-card">
            <div class="stat-header"><span class="stat-icon">⚡</span><span>Destrezza</span></div>
            <div class="stat-values">
              <span class="stat-base" id="base-dex">10</span>
              <span class="stat-mod" id="mod-dex"></span>
              <span class="stat-total" id="total-dex">10</span>
            </div>
            <div class="stat-desc">Evasione, precisione, iniziativa</div>
          </div>
          <div class="stat-card">
            <div class="stat-header"><span class="stat-icon">❤️</span><span>Vitalità</span></div>
            <div class="stat-values">
              <span class="stat-base" id="base-vit">10</span>
              <span class="stat-mod" id="mod-vit"></span>
              <span class="stat-total" id="total-vit">10</span>
            </div>
            <div class="stat-desc">Punti vita, resistenza fisica</div>
          </div>
          <div class="stat-card">
            <div class="stat-header"><span class="stat-icon">🧠</span><span>Intelligenza</span></div>
            <div class="stat-values">
              <span class="stat-base" id="base-int">10</span>
              <span class="stat-mod" id="mod-int"></span>
              <span class="stat-total" id="total-int">10</span>
            </div>
            <div class="stat-desc">Potere magico, mana massimo</div>
          </div>
        </div>
        
        <!-- Investimento punti (visibile solo se ci sono punti da investire) -->
        <div class="invest-section" id="invest-section" style="display:none">
          <h3 class="section-label">Punti da Investire: <span id="invest-available" class="invest-badge">0</span></h3>
          <div class="invest-grid">
            <div class="invest-row"><span>STR</span><button class="invest-btn" data-stat="str">+1</button><span class="invest-count" id="invest-str">0</span></div>
            <div class="invest-row"><span>DEX</span><button class="invest-btn" data-stat="dex">+1</button><span class="invest-count" id="invest-dex">0</span></div>
            <div class="invest-row"><span>VIT</span><button class="invest-btn" data-stat="vit">+1</button><span class="invest-count" id="invest-vit">0</span></div>
            <div class="invest-row"><span>INT</span><button class="invest-btn" data-stat="int">+1</button><span class="invest-count" id="invest-int">0</span></div>
          </div>
          <div class="invest-actions">
            <button class="invest-confirm" id="invest-confirm" disabled>Conferma</button>
            <button class="invest-reset" id="invest-reset">Reset</button>
          </div>
        </div>

        <div class="derived-stats">
          <h3 class="section-label">Statistiche Derivate</h3>
          <div class="derived-grid">
            <div class="derived-item"><span class="derived-label">Danno Fisico</span><span class="derived-value" id="derived-phys">x1.0</span></div>
            <div class="derived-item"><span class="derived-label">Danno Magico</span><span class="derived-value" id="derived-magic">x1.0</span></div>
            <div class="derived-item"><span class="derived-label">Precisione</span><span class="derived-value" id="derived-prec">60%</span></div>
            <div class="derived-item"><span class="derived-label">Evasione</span><span class="derived-value" id="derived-eva">0%</span></div>
            <div class="derived-item"><span class="derived-label">Attacchi/Turno</span><span class="derived-value" id="derived-apt">1.0</span></div>
            <div class="derived-item"><span class="derived-label">Velocita'</span><span class="derived-value" id="derived-speed">100%</span></div>
            <div class="derived-item"><span class="derived-label">Carico Max</span><span class="derived-value" id="derived-carry">50kg</span></div>
            <div class="derived-item"><span class="derived-label">Regen HP</span><span class="derived-value" id="derived-regen">0/min</span></div>
            <div class="derived-item"><span class="derived-label">Res. Veleni</span><span class="derived-value" id="derived-poison">0%</span></div>
            <div class="derived-item"><span class="derived-label">Res. Elementi</span><span class="derived-value" id="derived-element">0%</span></div>
            <div class="derived-item"><span class="derived-label">Bonus EXP</span><span class="derived-value" id="derived-xp">0%</span></div>
            <div class="derived-item"><span class="derived-label">Bonus Craft</span><span class="derived-value" id="derived-craft">0%</span></div>
          </div>
        </div>
      </section>
      
      <!-- Panel: Abilità -->
      <section class="panel" id="panel-skills">
        <div class="skills-section">
          <h3 class="section-label">Sfere Magiche</h3>
          <div class="skills-grid" id="skills-spheres"></div>
        </div>
        <div class="skills-section">
          <h3 class="section-label">Arti Marziali</h3>
          <div class="skills-grid" id="skills-martial"></div>
        </div>
        <div class="skills-section">
          <h3 class="section-label">Conoscenze</h3>
          <div class="skills-grid" id="skills-knowledge"></div>
        </div>
        <p class="empty-msg" id="skills-empty">Nessuna abilità appresa</p>
      </section>
      
      <!-- Panel: Equipaggiamento -->
      <section class="panel" id="panel-equipment">
        <div class="equip-layout">
          <!-- Paper Doll: 12 slot attorno alla silhouette -->
          <div class="equipment-side">
            <h3 class="section-label">Equipaggiamento</h3>
            <div class="paper-doll">
              <!-- Silhouette decorativa -->
              <div class="doll-silhouette" aria-hidden="true"></div>

              <!-- Riga 1: Testa -->
              <div class="equip-slot doll-head" data-slot="head">
                <span class="slot-label">Testa</span>
                <div class="slot-drop-area" id="slot-head"></div>
              </div>

              <!-- Riga 2: Schiena - Collo - Spalle -->
              <div class="equip-slot doll-back" data-slot="back">
                <span class="slot-label">Schiena</span>
                <div class="slot-drop-area" id="slot-back"></div>
              </div>
              <div class="equip-slot doll-neck" data-slot="neck">
                <span class="slot-label">Collo</span>
                <div class="slot-drop-area" id="slot-neck"></div>
              </div>
              <div class="equip-slot doll-shoulders" data-slot="shoulders">
                <span class="slot-label">Spalle</span>
                <div class="slot-drop-area" id="slot-shoulders"></div>
              </div>

              <!-- Riga 3: Mano Px - Petto - Mano Sx -->
              <div class="equip-slot doll-main-hand" data-slot="main_hand">
                <span class="slot-label">Mano Px</span>
                <div class="slot-drop-area" id="slot-main_hand"></div>
              </div>
              <div class="equip-slot doll-chest" data-slot="chest">
                <span class="slot-label">Petto</span>
                <div class="slot-drop-area" id="slot-chest"></div>
              </div>
              <div class="equip-slot doll-off-hand" data-slot="off_hand">
                <span class="slot-label">Mano Sx</span>
                <div class="slot-drop-area" id="slot-off_hand"></div>
              </div>

              <!-- Riga 4: Cintura -->
              <div class="equip-slot doll-belt" data-slot="belt">
                <span class="slot-label">Cintura</span>
                <div class="slot-drop-area" id="slot-belt"></div>
              </div>

              <!-- Riga 5: Anello - Guanti -->
              <div class="equip-slot doll-ring" data-slot="ring">
                <span class="slot-label">Anello</span>
                <div class="slot-drop-area" id="slot-ring"></div>
              </div>
              <div class="equip-slot doll-gloves" data-slot="gloves">
                <span class="slot-label">Guanti</span>
                <div class="slot-drop-area" id="slot-gloves"></div>
              </div>

              <!-- Riga 6: Gambe -->
              <div class="equip-slot doll-legs" data-slot="legs">
                <span class="slot-label">Gambe</span>
                <div class="slot-drop-area" id="slot-legs"></div>
              </div>

              <!-- Riga 7: Piedi -->
              <div class="equip-slot doll-feet" data-slot="feet">
                <span class="slot-label">Piedi</span>
                <div class="slot-drop-area" id="slot-feet"></div>
              </div>
            </div>
          </div>

          <!-- Inventario -->
          <div class="inventory-side">
            <div class="inv-header">
              <h3 class="section-label">Inventario</h3>
              <span class="inv-capacity" id="inv-capacity">0/32</span>
            </div>
            <div class="inv-toolbar">
              <div class="inv-tabs">
                <button class="inv-tab active" data-filter="all">Tutti</button>
                <button class="inv-tab" data-filter="equipment">Equip</button>
                <button class="inv-tab" data-filter="consumable">Consumo</button>
              </div>
              <select class="inv-sort" id="inv-sort">
                <option value="name">Nome</option>
                <option value="rarity">Rarit&agrave;</option>
                <option value="type">Tipo</option>
                <option value="level">Livello</option>
              </select>
            </div>
            <div class="inventory-drop-zone" id="inventory-drop-zone">
              <div class="inventory-grid" id="inventory-grid"></div>
              <p class="empty-msg" id="inv-empty">Inventario vuoto</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Panel: Diario / Quest Log -->
      <section class="panel" id="panel-journal">
        <div class="journal-layout">
          <!-- Sidebar: lista quest -->
          <aside class="journal-sidebar">
            <div class="journal-section">
              <h3 class="section-label">Quest Attive</h3>
              <div class="quest-list" id="quest-list-active">
                <p class="empty-msg" id="quest-empty-active">Nessuna quest attiva</p>
              </div>
            </div>
            <div class="journal-section">
              <h3 class="section-label">Storico</h3>
              <div class="quest-list" id="quest-list-history">
                <p class="empty-msg" id="quest-empty-history">Nessuna quest completata</p>
              </div>
            </div>
            <div class="journal-section">
              <h3 class="section-label">Note Personali</h3>
              <button class="btn-add-note" id="btn-add-note">+ Nuova Nota</button>
              <div class="notes-list" id="journal-notes-list"></div>
            </div>
          </aside>

          <!-- Detail panel -->
          <div class="journal-detail" id="journal-detail">
            <div class="journal-empty-state" id="journal-empty-state">
              <div class="journal-empty-icon">📜</div>
              <h2>Il Tuo Diario</h2>
              <p>Seleziona una quest dalla lista per vedere i dettagli, oppure crea una nota personale.</p>
            </div>
            <div class="quest-detail-view" id="quest-detail-view" style="display:none">
              <div class="quest-detail-header">
                <h2 class="quest-detail-name" id="quest-detail-name"></h2>
                <div class="quest-detail-badges">
                  <span class="quest-badge rarity-badge" id="quest-detail-rarity"></span>
                  <span class="quest-badge scope-badge" id="quest-detail-scope"></span>
                  <span class="quest-badge status-badge" id="quest-detail-status"></span>
                </div>
              </div>
              <div class="quest-detail-body">
                <div class="quest-objectives" id="quest-detail-objectives"></div>
                <div class="quest-rewards" id="quest-detail-rewards"></div>
                <div class="quest-dates" id="quest-detail-dates"></div>
              </div>
              <div class="quest-notes-section">
                <h3 class="section-label">Le Tue Note</h3>
                <textarea class="quest-notes-textarea" id="quest-notes-textarea" placeholder="Scrivi qui le tue considerazioni su questa quest..." rows="5"></textarea>
                <div class="quest-notes-status" id="quest-notes-status"></div>
              </div>
            </div>
            <div class="note-detail-view" id="note-detail-view" style="display:none">
              <textarea class="journal-note-textarea" id="journal-note-textarea" placeholder="Scrivi qui i tuoi appunti..." rows="12"></textarea>
              <div class="note-actions">
                <span class="note-save-status" id="note-save-status"></span>
                <button class="btn-delete-note" id="btn-delete-note">Elimina</button>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- Tooltip -->
    <div class="tooltip" id="tooltip"></div>
  </div>
</Layout>

<script>
  import { requireAuth } from '../lib/auth.js';
  import { getCharacterBySlot, equipItem as apiEquip, unequipItem as apiUnequip, moveEquipment as apiMove, useItem as apiUseItem, removeFromInventory as apiDiscard, investStats, getCharacterQuests, updateQuestNotes, getJournalNotes, saveJournalNote as apiSaveJournalNote, deleteJournalNote as apiDeleteJournalNote } from '../lib/api.js';
  import { initSheetRenderer } from '../lib/sheetRenderer.js';
  import { initEquipmentManager } from '../lib/equipmentManager.js';
  import { initJournalManager } from '../lib/journalManager.js';

  // Auth guard
  if (!requireAuth()) { /* redirecting */ }

  let character = null;
  const tooltipEl = document.getElementById('tooltip');

  const urlParams = new URLSearchParams(window.location.search);
  const slot = parseInt(urlParams.get('slot') || sessionStorage.getItem('currentSlot') || '0');
  sessionStorage.setItem('currentSlot', slot.toString());

  // ── Shared tooltip helpers ──
  function moveTooltip(e) {
    let x = e.clientX + 15;
    let y = e.clientY + 15;
    const rect = tooltipEl.getBoundingClientRect();
    if (x + 220 > window.innerWidth) x = e.clientX - 230;
    if (y + rect.height > window.innerHeight) y = e.clientY - rect.height - 15;
    tooltipEl.style.left = `${x}px`;
    tooltipEl.style.top = `${y}px`;
  }

  function hideTooltip() {
    tooltipEl.classList.remove('visible');
  }

  // ── Shared helpers ──
  const getCharacter = () => character;

  async function refreshCharacter() {
    const result = await getCharacterBySlot(slot);
    character = result.character;
    sheetRenderer.renderAll();
    equipmentMgr.render();
  }

  // ── Initialize modules ──
  const sheetRenderer = initSheetRenderer({
    getCharacter, investStats, refreshCharacter, tooltipEl, moveTooltip, hideTooltip,
  });

  const equipmentMgr = initEquipmentManager({
    getCharacter, apiEquip, apiUnequip, apiMove, apiUseItem, apiDiscard, refreshCharacter, tooltipEl, moveTooltip, hideTooltip,
  });

  const journalMgr = initJournalManager({
    getCharacter, getCharacterQuests, updateQuestNotes, getJournalNotes, apiSaveJournalNote, apiDeleteJournalNote,
  });

  // ── Tabs ──
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(`panel-${tab.dataset.tab}`).classList.add('active');
      if (tab.dataset.tab === 'journal' && !journalMgr.isLoaded()) {
        journalMgr.load();
      }
    });
  });

  const initialTab = urlParams.get('tab');
  if (initialTab) {
    const tabBtn = document.querySelector(`.tab[data-tab="${initialTab}"]`);
    if (tabBtn) {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
      tabBtn.classList.add('active');
      document.getElementById(`panel-${initialTab}`).classList.add('active');
    }
  }

  // ── Init ──
  async function init() {
    try {
      const result = await getCharacterBySlot(slot);
      if (!result.exists) { window.location.href = '/home'; return; }
      character = result.character;
      sheetRenderer.renderAll();
      equipmentMgr.render();
    } catch (e) {
      console.error('Errore:', e);
      window.location.href = '/home';
    }
  }

  init();

  if (initialTab === 'journal') {
    const waitForCharacter = setInterval(() => {
      if (character) { clearInterval(waitForCharacter); journalMgr.load(); }
    }, 100);
  }
</script>

<style>
  .sheet-page {
    min-height: 100vh;
    max-width: 950px;
    margin: 0 auto;
    padding: var(--space-md);
  }
  
  .sheet-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  
  /* Header */
  .char-header {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-lg);
    background: linear-gradient(135deg, var(--abyss) 0%, var(--shadow) 100%);
    border: 1px solid var(--mist);
    border-radius: 12px;
  }
  
  .char-portrait {
    position: relative;
    width: 80px;
    height: 80px;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid var(--accent);
    flex-shrink: 0;
  }
  
  .portrait-placeholder {
    width: 100%;
    height: 100%;
    background: var(--shadow);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: var(--mist);
  }
  
  .char-level {
    position: absolute;
    bottom: -4px;
    right: -4px;
    width: 24px;
    height: 24px;
    background: var(--accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: bold;
    color: var(--void);
  }
  
  .char-info { flex: 1; display: flex; flex-direction: column; justify-content: center; }
  .char-name { font-family: var(--font-narrative); font-size: 1.5rem; color: var(--parchment); margin: 0; }
  .char-class { color: var(--accent); font-size: 0.9rem; margin-bottom: var(--space-sm); }
  
  .char-bars { display: flex; flex-direction: column; gap: 6px; max-width: 300px; }
  .resource-bar { position: relative; height: 20px; background: var(--void); border-radius: 10px; overflow: hidden; border: 1px solid var(--mist); }
  .bar-fill { height: 100%; transition: width 0.5s ease; }
  .hp-bar .bar-fill { background: linear-gradient(90deg, #c0392b, #27ae60); }
  .mana-bar .bar-fill { background: linear-gradient(90deg, #2980b9, #9b59b6); }
  .xp-bar .bar-fill { background: linear-gradient(90deg, #c9a959, #f1c40f); }
  .bar-text { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-family: var(--font-mono); color: white; text-shadow: 0 1px 2px black; }

  /* Currency */
  .char-currency {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-top: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    background: var(--shadow);
    border: 1px solid rgba(218, 165, 32, 0.3);
    border-radius: 8px;
    max-width: 160px;
  }
  .currency-icon { font-size: 1.1rem; }
  .currency-value { font-family: var(--font-mono); font-size: 1rem; color: #f1c40f; font-weight: 600; }
  .currency-label { font-size: 0.7rem; color: var(--smoke); text-transform: uppercase; }

  /* Tabs */
  .tabs { display: flex; gap: var(--space-sm); }
  .tab { flex: 1; padding: var(--space-md); background: var(--shadow); border: 1px solid var(--mist); border-radius: 8px; color: var(--ash); font-size: 0.9rem; cursor: pointer; transition: all 0.2s; }
  .tab:hover { border-color: var(--accent); color: var(--bone); }
  .tab.active { background: var(--accent); border-color: var(--accent); color: var(--void); }
  
  /* Panels */
  .panel { display: none; background: var(--abyss); border: 1px solid var(--mist); border-radius: 12px; padding: var(--space-lg); }
  .panel.active { display: block; animation: fadeIn 0.2s ease; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  
  .section-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--smoke); margin: 0 0 var(--space-md); padding-bottom: var(--space-xs); border-bottom: 1px solid var(--mist); }
  .section-label small { font-weight: normal; opacity: 0.7; }
  .empty-msg { text-align: center; color: var(--smoke); font-style: italic; padding: var(--space-lg); }
  
  /* Stats */
  .stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-md); margin-bottom: var(--space-xl); }
  @media (max-width: 500px) { .stats-grid { grid-template-columns: 1fr; } }
  
  .stat-card { background: var(--shadow); border: 1px solid var(--mist); border-radius: 10px; padding: var(--space-md); }
  .stat-header { display: flex; align-items: center; gap: var(--space-sm); margin-bottom: var(--space-sm); font-family: var(--font-narrative); color: var(--parchment); }
  .stat-icon { font-size: 1.3rem; }
  .stat-values { display: flex; align-items: baseline; gap: var(--space-sm); margin-bottom: var(--space-xs); }
  .stat-base { font-family: var(--font-mono); font-size: 0.9rem; color: var(--ash); }
  .stat-mod { font-family: var(--font-mono); font-size: 0.8rem; }
  .stat-mod.buff { color: var(--vita); }
  .stat-mod.debuff { color: #e74c3c; }
  .stat-total { font-family: var(--font-mono); font-size: 1.5rem; font-weight: bold; color: var(--accent); margin-left: auto; }
  .stat-desc { font-size: 0.75rem; color: var(--smoke); }
  
  .derived-stats { margin-bottom: var(--space-xl); }
  .derived-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-sm); }
  @media (max-width: 600px) { .derived-grid { grid-template-columns: repeat(2, 1fr); } }
  .derived-item { background: var(--shadow); border-radius: 8px; padding: var(--space-sm); text-align: center; }
  .derived-label { display: block; font-size: 0.65rem; color: var(--smoke); text-transform: uppercase; margin-bottom: 4px; }
  .derived-value { font-family: var(--font-mono); font-size: 1rem; color: var(--accent); }

  /* Invest Section */
  .invest-section {
    background: linear-gradient(135deg, rgba(201, 169, 89, 0.08) 0%, var(--shadow) 100%);
    border: 1px solid var(--accent);
    border-radius: 10px;
    padding: var(--space-md);
    margin-bottom: var(--space-xl);
  }
  .invest-section .section-label {
    border-bottom: none;
    padding-bottom: 0;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .invest-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 24px;
    padding: 0 6px;
    background: var(--accent);
    color: var(--void);
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: bold;
    font-family: var(--font-mono);
  }
  .invest-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }
  @media (max-width: 500px) { .invest-grid { grid-template-columns: repeat(2, 1fr); } }
  .invest-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    background: var(--void);
    border: 1px solid var(--mist);
    border-radius: 8px;
    padding: var(--space-sm) var(--space-md);
  }
  .invest-row span:first-child {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: bold;
    color: var(--parchment);
    min-width: 30px;
  }
  .invest-btn {
    padding: 4px 12px;
    background: var(--accent);
    color: var(--void);
    border: none;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.15s;
  }
  .invest-btn:hover:not(:disabled) { background: var(--parchment); transform: scale(1.05); }
  .invest-btn:disabled { opacity: 0.3; cursor: not-allowed; }
  .invest-count {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: bold;
    color: var(--vita);
    min-width: 24px;
    text-align: center;
  }
  .invest-actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: flex-end;
  }
  .invest-confirm {
    padding: var(--space-sm) var(--space-lg);
    background: var(--vita);
    color: var(--void);
    border: none;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.2s;
  }
  .invest-confirm:hover:not(:disabled) { filter: brightness(1.1); transform: translateY(-1px); }
  .invest-confirm:disabled { opacity: 0.4; cursor: not-allowed; }
  .invest-reset {
    padding: var(--space-sm) var(--space-lg);
    background: transparent;
    border: 1px solid var(--mist);
    color: var(--ash);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .invest-reset:hover { border-color: var(--smoke); color: var(--bone); }
  
  /* Skills */
  .skills-section { margin-bottom: var(--space-lg); }
  .skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: var(--space-sm); }
  
  .skill-card { display: flex; align-items: center; gap: var(--space-sm); background: var(--shadow); border: 2px solid var(--skill-color); border-radius: 10px; padding: var(--space-sm); cursor: pointer; transition: all 0.2s; }
  .skill-card:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
  .skill-card.passive { border-style: dashed; }
  
  .skill-icon-wrap { position: relative; width: 40px; height: 40px; background: var(--void); border: 1px solid var(--skill-color); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .skill-icon { font-size: 1.3rem; }
  .skill-mastery { position: absolute; bottom: -4px; right: -4px; width: 18px; height: 18px; background: var(--skill-color); border-radius: 4px; font-size: 0.6rem; font-weight: bold; color: var(--void); display: flex; align-items: center; justify-content: center; }
  .skill-info { display: flex; flex-direction: column; min-width: 0; }
  .skill-name { font-size: 0.8rem; color: var(--bone); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .skill-type-label { font-size: 0.6rem; color: var(--smoke); text-transform: uppercase; }
  
  /* Equipment Layout */
  .equip-layout { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); }
  @media (max-width: 700px) { .equip-layout { grid-template-columns: 1fr; } }

  /* Paper Doll: 5 colonne x 7 righe */
  .paper-doll {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: repeat(7, auto);
    gap: var(--space-xs);
    position: relative;
    padding: var(--space-md) 0;
  }

  /* Silhouette decorativa dietro la griglia */
  .doll-silhouette {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 120px; height: 320px;
    background: linear-gradient(180deg, rgba(218,165,32,0.06) 0%, rgba(218,165,32,0.12) 50%, rgba(218,165,32,0.04) 100%);
    clip-path: polygon(
      40% 0%, 60% 0%,
      62% 8%, 65% 12%, 70% 14%, 72% 18%, 68% 22%,
      75% 28%, 80% 32%, 78% 38%,
      65% 36%, 62% 44%, 64% 52%, 62% 60%,
      68% 68%, 72% 78%, 70% 88%, 65% 100%,
      35% 100%, 30% 88%, 28% 78%, 32% 68%,
      38% 60%, 36% 52%, 38% 44%, 35% 36%,
      22% 38%, 20% 32%, 25% 28%,
      32% 22%, 28% 18%, 30% 14%, 35% 12%, 38% 8%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* Posizionamento slot nella griglia */
  .doll-head      { grid-column: 3; grid-row: 1; }
  .doll-back      { grid-column: 1; grid-row: 2; }
  .doll-neck      { grid-column: 3; grid-row: 2; }
  .doll-shoulders { grid-column: 5; grid-row: 2; }
  .doll-main-hand { grid-column: 1; grid-row: 3; }
  .doll-chest     { grid-column: 3; grid-row: 3; }
  .doll-off-hand  { grid-column: 5; grid-row: 3; }
  .doll-belt      { grid-column: 3; grid-row: 4; }
  .doll-ring      { grid-column: 1; grid-row: 5; }
  .doll-gloves    { grid-column: 5; grid-row: 5; }
  .doll-legs      { grid-column: 3; grid-row: 6; }
  .doll-feet      { grid-column: 3; grid-row: 7; }

  .equip-slot {
    background: var(--shadow);
    border: 2px dashed var(--mist);
    border-radius: 10px;
    padding: var(--space-xs);
    min-height: 80px;
    transition: all 0.2s;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .equip-slot.filled { border-style: solid; border-color: var(--accent); }
  .equip-slot.drop-valid { border-color: var(--vita); background: rgba(39, 174, 96, 0.1); }
  .equip-slot.drop-over { border-color: var(--vita); background: rgba(39, 174, 96, 0.25); transform: scale(1.02); }

  /* Two-hand lock: off_hand bloccata */
  .equip-slot.locked {
    border-color: var(--smoke);
    background: rgba(0, 0, 0, 0.3);
    opacity: 0.6;
    pointer-events: none;
  }
  .equip-slot.locked .slot-label { color: var(--smoke); }
  .slot-lock-icon {
    font-size: 1.2rem;
    color: var(--smoke);
    margin-top: var(--space-xs);
  }
  .slot-lock-text {
    font-size: 0.55rem;
    color: var(--smoke);
    font-style: italic;
    text-align: center;
  }

  .slot-label { display: block; font-size: 0.55rem; text-transform: uppercase; color: var(--smoke); margin-bottom: 2px; letter-spacing: 0.5px; text-align: center; }
  .slot-drop-area { min-height: 50px; display: flex; align-items: center; justify-content: center; width: 100%; }
  .slot-empty { font-size: 0.7rem; color: var(--smoke); font-style: italic; }
  .slot-icon { font-size: 1rem; color: var(--mist); display: block; text-align: center; margin-bottom: 2px; }

  /* Mobile: paper doll compatto 3 colonne */
  @media (max-width: 700px) {
    .paper-doll {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(6, auto);
    }
    .doll-silhouette { display: none; }
    .doll-head      { grid-column: 2; grid-row: 1; }
    .doll-back      { grid-column: 1; grid-row: 2; }
    .doll-neck      { grid-column: 2; grid-row: 2; }
    .doll-shoulders { grid-column: 3; grid-row: 2; }
    .doll-main-hand { grid-column: 1; grid-row: 3; }
    .doll-chest     { grid-column: 2; grid-row: 3; }
    .doll-off-hand  { grid-column: 3; grid-row: 3; }
    .doll-belt      { grid-column: 2; grid-row: 4; }
    .doll-ring      { grid-column: 1; grid-row: 4; }
    .doll-gloves    { grid-column: 3; grid-row: 4; }
    .doll-legs      { grid-column: 2; grid-row: 5; }
    .doll-feet      { grid-column: 2; grid-row: 6; }
  }
  
  /* Inventory */
  /* Inventory Header */
  .inv-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-xs); }
  .inv-capacity { font-family: var(--font-mono); font-size: 0.7rem; color: var(--smoke); background: var(--void); padding: 2px 8px; border-radius: 4px; }

  /* Inventory Toolbar */
  .inv-toolbar { display: flex; justify-content: space-between; align-items: center; gap: var(--space-sm); margin-bottom: var(--space-sm); }
  .inv-tabs { display: flex; gap: 2px; }
  .inv-tab {
    padding: 4px 10px;
    font-size: 0.65rem;
    text-transform: uppercase;
    background: var(--void);
    border: 1px solid var(--mist);
    border-radius: 4px;
    color: var(--smoke);
    cursor: pointer;
    transition: all 0.15s;
  }
  .inv-tab:hover { border-color: var(--accent); color: var(--bone); }
  .inv-tab.active { background: rgba(218, 165, 32, 0.15); border-color: var(--accent); color: var(--accent); }
  .inv-sort {
    padding: 4px 8px;
    font-size: 0.65rem;
    background: var(--void);
    border: 1px solid var(--mist);
    border-radius: 4px;
    color: var(--bone);
    cursor: pointer;
  }

  .inventory-drop-zone { min-height: 200px; border: 2px dashed transparent; border-radius: 10px; padding: var(--space-sm); transition: all 0.2s; }
  .inventory-drop-zone.drop-valid { border-color: var(--vita); background: rgba(39, 174, 96, 0.05); }
  .inventory-drop-zone.drop-over { border-color: var(--vita); background: rgba(39, 174, 96, 0.15); }

  .inventory-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: var(--space-sm); }

  /* Slot vuoti nella griglia */
  .inv-slot-empty {
    min-height: 60px;
    background: var(--shadow);
    border: 1px dashed var(--mist);
    border-radius: 8px;
    opacity: 0.3;
  }
  
  /* Item Cards */
  .item-card { display: flex; align-items: center; gap: var(--space-sm); background: linear-gradient(135deg, var(--shadow) 0%, var(--void) 100%); border: 2px solid var(--mist); border-radius: 10px; padding: var(--space-sm); cursor: grab; transition: all 0.2s; user-select: none; }
  .item-card:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
  .item-card.dragging { opacity: 0.5; cursor: grabbing; }
  
  .item-card.common { border-color: #7f8c8d; }
  .item-card.uncommon { border-color: #27ae60; }
  .item-card.rare { border-color: #3498db; }
  .item-card.epic { border-color: #9b59b6; }
  .item-card.legendary { border-color: #f39c12; box-shadow: 0 0 10px rgba(243, 156, 18, 0.3); }
  
  .item-icon { font-size: 1.5rem; width: 36px; text-align: center; flex-shrink: 0; }
  .item-details { display: flex; flex-direction: column; min-width: 0; flex: 1; }
  .item-name { font-size: 0.75rem; font-weight: 500; color: var(--bone); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .item-type { font-size: 0.6rem; color: var(--smoke); text-transform: capitalize; }
  .item-qty { font-size: 0.6rem; font-family: var(--font-mono); color: var(--accent); background: var(--void); padding: 2px 5px; border-radius: 4px; }

  /* Item card compatte dentro paper doll */
  .paper-doll .item-card {
    flex-direction: column;
    padding: 4px;
    gap: 2px;
    text-align: center;
    min-width: 0;
  }
  .paper-doll .item-icon { width: auto; font-size: 1.2rem; }
  .paper-doll .item-details { align-items: center; }
  .paper-doll .item-name { font-size: 0.6rem; white-space: normal; line-height: 1.2; text-align: center; }
  .paper-doll .item-type { display: none; }
  .paper-doll .item-qty { font-size: 0.5rem; }

  /* Lock content dentro slot bloccato */
  .slot-lock-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  
  /* Tooltip */
  .tooltip { position: fixed; background: var(--void); border: 1px solid var(--accent); border-radius: 10px; padding: var(--space-md); width: 220px; z-index: 1000; pointer-events: none; opacity: 0; transition: opacity 0.15s; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
  .tooltip.visible { opacity: 1; }
  
  .tip-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-sm); padding-bottom: var(--space-sm); border-bottom: 1px solid var(--mist); }
  .tip-name { font-family: var(--font-narrative); font-size: 1rem; color: var(--parchment); }
  .tip-type, .tip-rarity { font-size: 0.55rem; text-transform: uppercase; padding: 3px 6px; border-radius: 4px; background: var(--shadow); }
  .tip-type.active { background: rgba(231, 76, 60, 0.2); color: #e74c3c; }
  .tip-type.passive { background: rgba(52, 152, 219, 0.2); color: #3498db; }
  .tip-rarity.common { color: #7f8c8d; }
  .tip-rarity.uncommon { color: #27ae60; }
  .tip-rarity.rare { color: #3498db; }
  .tip-rarity.epic { color: #9b59b6; }
  .tip-rarity.legendary { color: #f39c12; }
  
  .tip-item-type { font-size: 0.7rem; color: var(--ash); text-transform: capitalize; margin-bottom: var(--space-sm); }
  .tip-desc { font-size: 0.75rem; color: var(--ash); line-height: 1.4; margin: 0 0 var(--space-sm); }
  .tip-mastery { font-size: 0.7rem; color: var(--accent); margin-bottom: var(--space-xs); }
  .tip-stat { font-size: 0.7rem; margin-top: 2px; }
  .tip-stat.bonus { color: var(--vita); }
  .tip-slots { font-size: 0.65rem; color: var(--smoke); margin-top: var(--space-sm); padding-top: var(--space-sm); border-top: 1px solid var(--mist); }
  .tip-footer { margin-top: var(--space-sm); padding-top: var(--space-sm); border-top: 1px solid var(--mist); font-family: var(--font-mono); font-size: 0.55rem; color: var(--smoke); }

  /* Tooltip: linee combattimento */
  .tip-combat { font-size: 0.7rem; color: var(--bone); margin-top: 2px; }
  .tip-meta { font-size: 0.6rem; color: var(--smoke); margin-top: var(--space-xs); font-family: var(--font-mono); }

  /* Tooltip: confronto stats */
  .tip-comparison { margin-top: var(--space-sm); padding: var(--space-xs) var(--space-sm); background: rgba(0,0,0,0.3); border-radius: 6px; border-left: 3px solid var(--accent); }
  .tip-comp-label { font-size: 0.6rem; color: var(--smoke); text-transform: uppercase; margin-bottom: 2px; }
  .tip-comp-stat { display: inline-block; font-size: 0.7rem; font-weight: 600; margin-right: var(--space-sm); }
  .tip-comp-stat.stat-up { color: #27ae60; }
  .tip-comp-stat.stat-down { color: #e74c3c; }

  /* Tooltip: use effect consumabili */
  .tip-use-effect { font-size: 0.75rem; color: var(--accent); margin-top: var(--space-xs); padding: 3px 0; font-weight: 500; }

  /* Context Menu */
  .item-context-menu {
    position: fixed;
    background: var(--void);
    border: 1px solid var(--accent);
    border-radius: 8px;
    padding: var(--space-xs) 0;
    min-width: 180px;
    z-index: 2000;
    box-shadow: 0 8px 24px rgba(0,0,0,0.6);
  }
  .ctx-option {
    padding: var(--space-xs) var(--space-md);
    font-size: 0.8rem;
    color: var(--bone);
    cursor: pointer;
    transition: background 0.15s;
  }
  .ctx-option:hover {
    background: rgba(218, 165, 32, 0.15);
    color: var(--parchment);
  }

  /* Item card consumabile */
  .item-card.consumable { border-style: dashed; cursor: pointer; }
  .item-card.consumable:hover { border-color: var(--accent); }

  /* ═══════════════════════════════════════════════════════ */
  /* JOURNAL / QUEST LOG                                    */
  /* ═══════════════════════════════════════════════════════ */

  .journal-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-lg);
    min-height: 400px;
  }
  @media (max-width: 700px) {
    .journal-layout { grid-template-columns: 1fr; }
    .journal-detail { min-height: 300px; }
  }

  .journal-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    overflow-y: auto;
    max-height: 600px;
    padding-right: var(--space-sm);
  }

  .journal-section { }
  .journal-section .section-label { font-size: 0.65rem; }

  .btn-add-note {
    display: block;
    width: 100%;
    padding: var(--space-sm);
    margin-bottom: var(--space-sm);
    background: transparent;
    border: 1px dashed var(--accent);
    border-radius: 8px;
    color: var(--accent);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-add-note:hover { background: rgba(201, 169, 89, 0.1); border-style: solid; }

  /* Quest cards */
  .quest-card {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--shadow);
    border-left: 3px solid var(--quest-color, var(--mist));
    border-radius: 0 8px 8px 0;
    cursor: pointer;
    transition: all 0.2s;
    margin-bottom: var(--space-xs);
  }
  .quest-card:hover { background: var(--void); transform: translateX(3px); }
  .quest-card.selected { background: rgba(201, 169, 89, 0.12); border-left-color: var(--accent); }

  .quest-card-icon { font-size: 1rem; flex-shrink: 0; }
  .quest-card-info { display: flex; flex-direction: column; min-width: 0; }
  .quest-card-name { font-size: 0.8rem; color: var(--bone); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .quest-card-progress { font-size: 0.65rem; color: var(--smoke); font-family: var(--font-mono); }

  /* Note cards */
  .note-card {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-sm);
    background: var(--shadow);
    border-left: 3px solid var(--mist);
    border-radius: 0 8px 8px 0;
    cursor: pointer;
    transition: all 0.2s;
    margin-bottom: var(--space-xs);
  }
  .note-card:hover { background: var(--void); }
  .note-card.selected { background: rgba(201, 169, 89, 0.12); border-left-color: var(--accent); }
  .note-card-preview { font-size: 0.75rem; color: var(--bone); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .note-card-date { font-size: 0.6rem; color: var(--smoke); font-family: var(--font-mono); }

  /* Detail panel */
  .journal-detail {
    background: var(--shadow);
    border: 1px solid var(--mist);
    border-radius: 10px;
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
  }

  .journal-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1;
    text-align: center;
    color: var(--smoke);
    gap: var(--space-md);
  }
  .journal-empty-icon { font-size: 3rem; opacity: 0.4; }
  .journal-empty-state h2 { font-family: var(--font-narrative); color: var(--ash); margin: 0; font-size: 1.2rem; }
  .journal-empty-state p { font-size: 0.8rem; max-width: 250px; }

  /* Quest detail view */
  .quest-detail-view { display: flex; flex-direction: column; gap: var(--space-md); }

  .quest-detail-header { margin-bottom: var(--space-sm); }
  .quest-detail-name { font-family: var(--font-narrative); font-size: 1.4rem; color: var(--parchment); margin: 0 0 var(--space-sm); }
  .quest-detail-badges { display: flex; gap: var(--space-sm); flex-wrap: wrap; }

  .quest-badge {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 3px 8px;
    border-radius: 4px;
    font-weight: 600;
  }
  .rarity-badge { color: #fff; }
  .scope-badge { background: var(--void); color: var(--ash); border: 1px solid var(--mist); }
  .status-badge { background: var(--void); }
  .status-active { color: #f39c12; border: 1px solid #f39c12; }
  .status-completed { color: #2ecc71; border: 1px solid #2ecc71; }
