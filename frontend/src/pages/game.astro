---
// game.astro - Pagina di gioco principale (chat con GM)
import Layout from '../components/Layout.astro';
import Header from '../components/ui/Header.astro';
import Button from '../components/ui/Button.astro';
import ChatContainer from '../components/chat/ChatContainer.astro';
import MiniMap from '../components/map/MiniMap.astro';
---

<Layout title="STATISFY RPG - Gioco">
  <div class="game-container">
    <Header showBackButton backHref="/characters?mode=play">
      <div class="header-info">
        <span class="char-name" id="header-name">—</span>
        <span class="char-hp">
          HP: <span id="header-hp">0</span>/<span id="header-hp-max">0</span>
        </span>
        <span class="char-xp">
          XP: <span id="header-xp">0</span>/<span id="header-xp-max">100</span>
          <span class="char-level-badge" id="header-level">Lv.1</span>
        </span>
      </div>
      <div class="header-links">
        <a href="/sheet" class="btn-sheet" id="btn-sheet">
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="1.5" fill="none">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
          </svg>
          Scheda
        </a>
        <a href="/sheet?tab=journal" class="btn-sheet" id="btn-journal">
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="1.5" fill="none">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
          </svg>
          Diario
        </a>
      </div>
    </Header>
    
    <ChatContainer />
  </div>
  
  <!-- Mini-mappa -->
  <MiniMap />

  <!-- Memo FAB -->
  <button class="memo-fab" id="memo-fab" title="Appunti rapidi">
    <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none">
      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
      <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
    </svg>
  </button>

  <!-- Shop Overlay -->
  <div class="shop-overlay" id="shop-overlay">
    <div class="shop-modal">
      <div class="shop-header">
        <div class="shop-npc-info">
          <h3 class="shop-npc-name" id="shop-npc-name">Mercante</h3>
          <span class="shop-npc-title" id="shop-npc-title"></span>
        </div>
        <div class="shop-player-corone">
          <span>🪙</span>
          <span id="shop-corone">0</span>
        </div>
        <button class="shop-close" id="shop-close">&times;</button>
      </div>
      <div class="shop-body">
        <div class="shop-column">
          <h4 class="shop-col-title">In Vendita</h4>
          <div class="shop-items" id="shop-items-list"></div>
        </div>
        <div class="shop-column">
          <h4 class="shop-col-title">Il Tuo Inventario</h4>
          <div class="shop-items" id="shop-player-items"></div>
        </div>
      </div>
      <div class="shop-footer" id="shop-footer"></div>
    </div>
  </div>

  <!-- Memo Popup -->
  <div class="memo-overlay" id="memo-overlay">
    <div class="memo-popup" id="memo-popup">
      <div class="memo-header">
        <h3>Appunti Rapidi</h3>
        <button class="memo-close" id="memo-close">&times;</button>
      </div>
      <textarea class="memo-textarea" id="memo-textarea" placeholder="Scrivi qui i tuoi appunti temporanei..." rows="8"></textarea>
      <div class="memo-footer">
        <span class="memo-status" id="memo-status">Salvato in locale</span>
      </div>
    </div>
  </div>

  <!-- Quick Interactions: Vendor Panel -->
  <div class="qi-panel" id="qi-panel" style="display:none">
    <button class="qi-header" id="qi-header">
      <span class="qi-title">Mercanti</span>
      <svg class="qi-chevron" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>
    <div class="qi-body" id="qi-body"></div>
  </div>
</Layout>

<script>
  import { requireAuth } from '../lib/auth.js';
  import { getCharacterBySlot, getCurrentLocation, getShop, buyFromShop, sellToShop, getNearbyVendors } from '../lib/api.js';
  import { initChatManager } from '../lib/chatManager.js';
  import { initMemoManager } from '../lib/memoManager.js';

  // Auth guard
  if (!requireAuth()) { /* redirecting */ }

  // Shared state
  let character = null;
  let currentLocationId = '';
  let miniMap = null;

  // Slot e location target dalla URL
  const urlParams = new URLSearchParams(window.location.search);
  const slot = parseInt(urlParams.get('slot') || '0');
  const targetLocation = urlParams.get('location') || '';
  sessionStorage.setItem('currentSlot', slot.toString());

  // Aggiorna link scheda e diario con slot
  const sheetLink = document.getElementById('btn-sheet');
  if (sheetLink) sheetLink.href = `/sheet?slot=${slot}`;
  const journalLink = document.getElementById('btn-journal');
  if (journalLink) journalLink.href = `/sheet?slot=${slot}&tab=journal`;

  // Back button → mappa invece di characters
  const backLink = document.querySelector('.header__back');
  if (backLink) backLink.href = `/map?slot=${slot}`;

  // Inizializza Chat Manager
  const chat = initChatManager({
    getCharacter: () => character,
    setCharacter: (c) => { character = c; },
    getCurrentLocationId: () => currentLocationId,
    setCurrentLocationId: (id) => { currentLocationId = id; },
    onHeaderUpdate: () => updateHeaderInfo(),
    onMapRefresh: () => { miniMap?.refresh(); refreshVendorPanel(); },
    chatMessages: document.getElementById('chat-messages'),
    chatInput: document.getElementById('chat-input'),
    btnSend: document.getElementById('btn-send'),
    typingIndicator: document.getElementById('typing-indicator'),
  });

  // Inizializza Memo Manager
  initMemoManager({
    getCharacterId: () => character?.id ?? null,
    memoFab: document.getElementById('memo-fab'),
    memoOverlay: document.getElementById('memo-overlay'),
    memoClose: document.getElementById('memo-close'),
    memoTextarea: document.getElementById('memo-textarea'),
    memoStatus: document.getElementById('memo-status'),
  });

  // ══════════════════════════════════════════════════════
  // SHOP OVERLAY
  // ══════════════════════════════════════════════════════

  const shopOverlay = document.getElementById('shop-overlay');
  const shopClose = document.getElementById('shop-close');
  let currentShopNpcId = null;

  shopClose.addEventListener('click', () => {
    shopOverlay.classList.remove('open');
    currentShopNpcId = null;
  });

  shopOverlay.addEventListener('click', (e) => {
    if (e.target === shopOverlay) {
      shopOverlay.classList.remove('open');
      currentShopNpcId = null;
    }
  });

  // Listener per evento [SHOP: npc_id] dal tagParser
  window.addEventListener('open-shop', async (e) => {
    const npcId = e.detail?.npcId;
    if (!npcId || !character) return;
    await openShop(npcId);
  });

  async function openShop(npcId) {
    try {
      const shop = await getShop(character.id, npcId);
      currentShopNpcId = npcId;

      // Aggiorna header
      document.getElementById('shop-npc-name').textContent = shop.npc_name;
      document.getElementById('shop-npc-title').textContent = shop.npc_title;
      document.getElementById('shop-corone').textContent = character.corone || 0;

      // Render lista NPC
      const shopList = document.getElementById('shop-items-list');
      shopList.innerHTML = shop.items.map(item => {
        const stockText = item.stock === -1 ? '' : ` (${item.stock} disp.)`;
        const outOfStock = item.stock === 0;
        return `
          <div class="shop-item ${outOfStock ? 'out-of-stock' : ''}" data-eq-id="${item.id}">
            <div class="shop-item-info">
              <span class="shop-item-name ${item.rarity || 'common'}">${item.name}</span>
              <span class="shop-item-type">${item.type}${stockText}</span>
            </div>
            <button class="shop-buy-btn" ${outOfStock ? 'disabled' : ''} data-eq-id="${item.id}">
              🪙 ${item.buy_price}
            </button>
          </div>
        `;
      }).join('') || '<p class="shop-empty">Nessun item in vendita</p>';

      // Render inventario giocatore (per vendere)
      await refreshShopPlayerItems(shop);

      // Bind buy buttons
      shopList.querySelectorAll('.shop-buy-btn:not([disabled])').forEach(btn => {
        btn.addEventListener('click', async () => {
          const eqId = btn.dataset.eqId;
          try {
            const result = await buyFromShop(character.id, npcId, eqId);
            if (result.success) {
              // Refresh character e shop
              const charResult = await getCharacterBySlot(slot);
              if (charResult.exists) character = charResult.character;
              await openShop(npcId);
            }
          } catch (err) {
            console.error('Buy error:', err);
          }
        });
      });

      shopOverlay.classList.add('open');
    } catch (err) {
      console.error('Shop error:', err);
    }
  }

  async function refreshShopPlayerItems(shop) {
    const playerList = document.getElementById('shop-player-items');
    const inv = character.inventory || [];
    const sellPrices = shop.sell_prices || {};
    const sellModifier = shop.sell_modifier || 0.5;

    if (!inv.length) {
      playerList.innerHTML = '<p class="shop-empty">Inventario vuoto</p>';
      return;
    }

    playerList.innerHTML = inv.map(item => {
      const eq = item;
      const itemName = eq.item_name || eq.name;
      // Usa prezzo pre-calcolato dal backend; fallback locale solo se manca
      const sellPrice = sellPrices[itemName]
        ?? Math.max(1, Math.floor((eq.sell_price || 0) * sellModifier));
      return `
        <div class="shop-item">
          <div class="shop-item-info">
            <span class="shop-item-name ${eq.rarity || 'common'}">${itemName}</span>
            <span class="shop-item-type">${eq.type || 'Oggetto'}${eq.quantity > 1 ? ` x${eq.quantity}` : ''}</span>
          </div>
          <button class="shop-sell-btn" data-item-name="${itemName}">
            Vendi 🪙 ${sellPrice}
          </button>
        </div>
      `;
    }).join('');

    // Bind sell buttons
    playerList.querySelectorAll('.shop-sell-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const itemName = btn.dataset.itemName;
        try {
          const result = await sellToShop(character.id, currentShopNpcId, itemName);
          if (result.success) {
            const charResult = await getCharacterBySlot(slot);
            if (charResult.exists) character = charResult.character;
            await openShop(currentShopNpcId);
          }
        } catch (err) {
          console.error('Sell error:', err);
        }
      });
    });
  }

  // Header update
  function updateHeaderInfo() {
    if (!character) return;
    document.getElementById('header-name').textContent = character.name;
    document.getElementById('header-hp').textContent = character.hp_current;
    document.getElementById('header-hp-max').textContent = character.hp_max;
    document.getElementById('header-xp').textContent = character.xp || 0;
    document.getElementById('header-xp-max').textContent = character.xp_next || 100;
    document.getElementById('header-level').textContent = `Lv.${character.level || 1}`;
  }

  // ══════════════════════════════════════════════════════
  // QUICK INTERACTIONS: VENDOR PANEL
  // ══════════════════════════════════════════════════════

  const qiPanel = document.getElementById('qi-panel');
  const qiHeader = document.getElementById('qi-header');
  const qiBody = document.getElementById('qi-body');
  let qiCollapsed = false;

  qiHeader.addEventListener('click', () => {
    qiCollapsed = !qiCollapsed;
    qiBody.style.display = qiCollapsed ? 'none' : '';
    qiPanel.classList.toggle('collapsed', qiCollapsed);
  });

  const VENDOR_ICONS = {
    blacksmith: '\u2692\uFE0F',
    innkeeper: '\uD83C\uDF7A',
    alchemist: '\uD83E\uDDEA',
    merchant: '\uD83C\uDFEA',
    herbalist: '\uD83C\uDF3F',
  };

  async function refreshVendorPanel() {
    if (!character) return;
    try {
      const data = await getNearbyVendors(character.id);
      const vendors = data.vendors || [];

      if (!vendors.length) {
        qiPanel.style.display = 'none';
        return;
      }

      qiBody.innerHTML = vendors.map(v => {
        const icon = VENDOR_ICONS[v.role] || VENDOR_ICONS.merchant;
        return `
          <button class="qi-vendor-card" data-npc-id="${v.npc_id}">
            <span class="qi-vendor-icon">${icon}</span>
            <div class="qi-vendor-info">
              <span class="qi-vendor-name">${v.name}</span>
              <span class="qi-vendor-title">${v.title || v.role}</span>
            </div>
          </button>
        `;
      }).join('');

      // Bind click → open shop
      qiBody.querySelectorAll('.qi-vendor-card').forEach(card => {
        card.addEventListener('click', () => openShop(card.dataset.npcId));
      });

      qiPanel.style.display = '';
    } catch (e) {
      console.warn('Vendor panel error:', e);
      qiPanel.style.display = 'none';
    }
  }

  // Init
  async function init() {
    try {
      const result = await getCharacterBySlot(slot);
      if (!result.exists) { window.location.href = '/home'; return; }

      character = result.character;
      updateHeaderInfo();

      try {
        const locResult = await getCurrentLocation(character.id);
        if (locResult.current_location) currentLocationId = locResult.current_location.id;
      } catch (e) { console.log('Nessuna location salvata'); }

      // Se arriviamo dalla mappa con una location specifica, switcha
      if (targetLocation && targetLocation !== currentLocationId) {
        try {
          await chat.handleLocationChange(currentLocationId, targetLocation);
          currentLocationId = targetLocation;
          // NON chiamare loadHistory — handleLocationChange ha gia' caricato dal backend
        } catch (e) {
          console.warn('Switch location da mappa fallito:', e);
          chat.loadHistory(); // fallback: carica da localStorage
        }
      } else {
        chat.loadHistory(); // Nessun switch: carica normalmente da localStorage
      }

      if (window.MiniMapController) {
        miniMap = new window.MiniMapController();
        miniMap.setCharacterId(character.id);
        miniMap.setOnMove(async (fromId, toId) => {
          await chat.handleLocationChange(fromId, toId);
        });
        miniMap.refresh();
      }

      // Carica vendor panel
      refreshVendorPanel();
    } catch (e) {
      console.error('Errore caricamento personaggio:', e);
      chat.addMessage('*Impossibile raggiungere il server... ritorno alla selezione personaggi.*', false);
      setTimeout(() => { window.location.href = '/home'; }, 3000);
    }
  }

  // Salva chat prima di uscire dalla pagina
  window.addEventListener('beforeunload', () => {
    chat.saveCurrentChat?.();
  });

  init();
</script>

<style>
  .game-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    max-width: 900px;
    margin: 0 auto;
    padding: var(--space-md);
  }
  
  .header-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    margin-right: var(--space-md);
  }
  
  .char-name {
    font-family: var(--font-narrative);
    font-size: 1rem;
    color: var(--parchment);
  }
  
  .char-hp {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--vita);
  }

  .char-xp {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .char-level-badge {
    background: var(--accent);
    color: var(--void);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: bold;
  }

  .header-links {
    display: flex;
    gap: var(--space-sm);
  }

  .btn-sheet {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--shadow);
    border: 1px solid var(--mist);
    border-radius: 6px;
    color: var(--bone);
    font-family: var(--font-ui);
    font-size: 0.9rem;
    text-decoration: none;
    transition: var(--transition-fast);
  }

  .btn-sheet:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  
  /* ═══════════════════════════════════════
     MESSAGE HEADER & FOCUS BUTTON
     ═══════════════════════════════════════ */
  
  .message__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xs);
  }
  
  .btn-focus {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    background: transparent;
    border: 1px solid var(--mist);
    border-radius: 4px;
    color: var(--ash);
    font-family: var(--font-ui);
    font-size: 0.7rem;
    cursor: pointer;
    transition: var(--transition-fast);
    opacity: 0;
  }
  
  .message--ai:hover .btn-focus {
    opacity: 1;
  }
  
  .btn-focus:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(201, 169, 89, 0.1);
  }
  
  .btn-focus:disabled {
    opacity: 0.5;
    cursor: wait;
  }
  
  .btn-focus svg {
    flex-shrink: 0;
  }
  
  /* Loading spinner nel pulsante */
  .loading-spinner {
    display: inline-block;
    width: 12px;
    height: 12px;
    border: 2px solid var(--mist);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  
  /* Messaggio espanso */
  .message--ai.expanded {
    border-left: 3px solid var(--accent);
    background: linear-gradient(90deg, rgba(201, 169, 89, 0.05) 0%, transparent 100%);
  }
  
  .message--ai.expanded .btn-focus {
    opacity: 1;
    border-color: var(--accent);
    color: var(--accent);
  }
  
  /* ═══════════════════════════════════════
     RECAP MESSAGE
     ═══════════════════════════════════════ */
  
  .message--recap {
    background: linear-gradient(135deg, rgba(139, 115, 85, 0.15) 0%, rgba(139, 115, 85, 0.05) 100%);
    border: 1px solid rgba(139, 115, 85, 0.3);
    border-radius: 8px;
    padding: var(--space-md);
    margin: var(--space-md) 0;
  }
  
  .message--recap .message__label {
    color: #b8a67d;
    font-family: var(--font-narrative);
    font-size: 0.85rem;
    margin-bottom: var(--space-xs);
  }
  
  .message--recap .message__content {
    color: var(--bone);
    font-style: italic;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* ═══════════════════════════════════════
     LEVEL-UP MESSAGE
     ═══════════════════════════════════════ */

  .message--levelup {
    background: linear-gradient(135deg, rgba(201, 169, 89, 0.2) 0%, rgba(201, 169, 89, 0.05) 100%);
    border: 2px solid var(--accent);
    border-radius: 8px;
    padding: var(--space-md);
    margin: var(--space-md) 0;
    text-align: center;
    animation: levelUpGlow 1.5s ease-in-out;
  }

  .message--levelup .message__label {
    color: var(--accent);
    font-family: var(--font-narrative);
    font-size: 1.2rem;
    font-weight: bold;
    margin-bottom: var(--space-sm);
    text-shadow: 0 0 10px rgba(201, 169, 89, 0.5);
  }

  .message--levelup .message__content {
    color: var(--parchment);
    font-size: 0.9rem;
    line-height: 1.8;
  }

  .message--levelup .message__content strong {
    font-size: 1.1rem;
    color: var(--accent);
  }

  @keyframes levelUpGlow {
    0%, 100% { box-shadow: 0 0 5px rgba(201, 169, 89, 0.3); }
    50% { box-shadow: 0 0 25px rgba(201, 169, 89, 0.6); }
  }

  /* ═══════════════════════════════════════
     CORONE NOTIFICATION MESSAGE
     ═══════════════════════════════════════ */

  .message--corone {
    border-radius: 8px;
    padding: var(--space-sm) var(--space-md);
    margin: var(--space-sm) 0;
    text-align: center;
    font-size: 0.85rem;
  }

  .message--corone .message__label {
    font-family: var(--font-narrative);
    font-size: 0.8rem;
    margin-bottom: 2px;
  }

  .message--corone .message__content {
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .message--corone-gain {
    background: linear-gradient(135deg, rgba(241, 196, 15, 0.15) 0%, rgba(241, 196, 15, 0.05) 100%);
    border: 1px solid rgba(241, 196, 15, 0.4);
  }
  .message--corone-gain .message__label { color: #f1c40f; }
  .message--corone-gain .message__content strong { color: #f1c40f; }

  .message--corone-loss {
    background: linear-gradient(135deg, rgba(231, 76, 60, 0.12) 0%, rgba(231, 76, 60, 0.04) 100%);
    border: 1px solid rgba(231, 76, 60, 0.35);
  }
  .message--corone-loss .message__label { color: #e74c3c; }
  .message--corone-loss .message__content strong { color: #e74c3c; }

  /* ═══════════════════════════════════════
     MEMO FAB & POPUP
     ═══════════════════════════════════════ */

  .memo-fab {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--accent);
    border: none;
    color: var(--void);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4), 0 0 12px rgba(201, 169, 89, 0.2);
    transition: all 0.2s;
    z-index: 900;
  }
  .memo-fab:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5), 0 0 20px rgba(201, 169, 89, 0.35);
  }

  /* ═══════════════════════════════════════ */
  /* SHOP OVERLAY                           */
  /* ═══════════════════════════════════════ */

  .shop-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 3000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: var(--space-md);
  }
  .shop-overlay.open { display: flex; }

  .shop-modal {
    background: var(--shadow);
    border: 2px solid var(--accent);
    border-radius: 12px;
    width: 100%;
    max-width: 700px;
    max-height: 80vh;
    display: flex;
