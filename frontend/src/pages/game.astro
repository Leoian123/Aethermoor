---
// game.astro - Pagina di gioco principale (chat con GM)
import Layout from '../components/Layout.astro';
import Header from '../components/ui/Header.astro';
import Button from '../components/ui/Button.astro';
import ChatContainer from '../components/chat/ChatContainer.astro';
import MiniMap from '../components/map/MiniMap.astro';
---

<Layout title="STATISFY RPG - Gioco">
  <div class="game-container">
    <Header showBackButton>
      <div class="header-info">
        <span class="char-name" id="header-name">—</span>
        <span class="char-hp">
          HP: <span id="header-hp">0</span>/<span id="header-hp-max">0</span>
        </span>
      </div>
      <a href="/sheet" class="btn-sheet" id="btn-sheet">
        <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="1.5" fill="none">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
        </svg>
        Scheda
      </a>
    </Header>
    
    <ChatContainer />
  </div>
  
  <!-- Mini-mappa -->
  <MiniMap />
</Layout>

<script>
  import { parseTags, formatTagsForDisplay, stripLocationTags } from '../lib/tagParser.js';
  import { sendChatMessage, expandMessage, switchLocation, getCharacterBySlot, getCurrentLocation } from '../lib/api.js';
  
  // State
  let character = null;
  let history = [];
  let miniMap = null;
  let currentLocationId = '';
  
  // DOM
  const chatMessages = document.getElementById('chat-messages');
  const chatInput = document.getElementById('chat-input') as HTMLTextAreaElement;
  const btnSend = document.getElementById('btn-send') as HTMLButtonElement;
  const typingIndicator = document.getElementById('typing-indicator');
  
  // Ottieni slot dalla URL
  const urlParams = new URLSearchParams(window.location.search);
  const slot = parseInt(urlParams.get('slot') || '0');
  
  // Salva slot per la pagina sheet
  sessionStorage.setItem('currentSlot', slot.toString());
  
  // Aggiorna link scheda con slot
  const sheetLink = document.getElementById('btn-sheet') as HTMLAnchorElement;
  if (sheetLink) {
    sheetLink.href = `/sheet?slot=${slot}`;
  }
  
  // ═══════════════════════════════════════
  // CHAT PERSISTENCE (localStorage)
  // ═══════════════════════════════════════
  
  function getChatStorageKey(): string {
    if (!character) return '';
    return `statisfy_chat_${character.id}_${currentLocationId || 'default'}`;
  }
  
  function saveChat(): void {
    const key = getChatStorageKey();
    if (!key) return;
    try {
      localStorage.setItem(key, JSON.stringify(history));
    } catch (e) {
      console.warn('Impossibile salvare chat:', e);
    }
  }
  
  function loadChat(): void {
    const key = getChatStorageKey();
    if (!key) return;
    try {
      const saved = localStorage.getItem(key);
      if (saved) {
        history = JSON.parse(saved);
        // Ripopola UI
        history.forEach(msg => {
          addMessage(msg.content, msg.role === 'user', undefined, false);
        });
      }
    } catch (e) {
      console.warn('Impossibile caricare chat:', e);
      history = [];
    }
  }
  
  // ═══════════════════════════════════════
  // INIT
  // ═══════════════════════════════════════
  
  async function init() {
    try {
      const result = await getCharacterBySlot(slot);
      
      if (!result.exists) {
        window.location.href = '/';
        return;
      }
      
      character = result.character;
      updateHeaderInfo();
      
      // Carica location corrente
      try {
        const locResult = await getCurrentLocation(character.id);
        if (locResult.current_location) {
          currentLocationId = locResult.current_location.id;
        }
      } catch (e) {
        console.log('Nessuna location salvata');
      }
      
      // Carica chat salvata per questa location
      loadChat();
      
      // Inizializza MiniMap
      if (window.MiniMapController) {
        miniMap = new window.MiniMapController();
        miniMap.setCharacterId(character.id);
        miniMap.refresh();
      }
      
    } catch (e) {
      console.error('Errore caricamento personaggio:', e);
      alert('Errore di connessione al server');
      window.location.href = '/';
    }
  }
  
  function updateHeaderInfo() {
    if (!character) return;
    
    document.getElementById('header-name').textContent = character.name;
    document.getElementById('header-hp').textContent = character.hp_current;
    document.getElementById('header-hp-max').textContent = character.hp_max;
  }
  
  // ═══════════════════════════════════════
  // CHAT
  // ═══════════════════════════════════════
  
  function addMessage(content: string, isUser = false, messageId?: string, persist = true) {
    const msgDiv = document.createElement('div');
    msgDiv.className = `message message--${isUser ? 'user' : 'ai'}`;
    if (messageId) msgDiv.dataset.messageId = messageId;
    
    let displayContent = content;
    if (!isUser) {
      // Rimuovi tag location XML e formatta tag meccanici
      displayContent = stripLocationTags(content);
      displayContent = formatTagsForDisplay(displayContent);
    }
    
    // Struttura messaggio con pulsante Focus per messaggi GM
    if (isUser) {
      msgDiv.innerHTML = `
        <div class="message__label">Tu</div>
        <div class="message__content">${displayContent}</div>
      `;
    } else {
      const id = messageId || `msg-${Date.now()}`;
      msgDiv.innerHTML = `
        <div class="message__header">
          <span class="message__label">Game Master</span>
          <button class="btn-focus" data-msg-id="${id}" title="Espandi con più dettagli">
            <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="M21 21l-4.35-4.35"></path>
              <path d="M11 8v6M8 11h6"></path>
            </svg>
            Focus
          </button>
        </div>
        <div class="message__content" data-original="${encodeURIComponent(content)}">${displayContent}</div>
      `;
      
      // Aggiungi listener per il pulsante Focus
      const focusBtn = msgDiv.querySelector('.btn-focus');
      focusBtn?.addEventListener('click', () => handleFocus(id, content));
    }
    
    if (typingIndicator && chatMessages) {
      chatMessages.insertBefore(msgDiv, typingIndicator);
    } else {
      chatMessages?.appendChild(msgDiv);
    }
    
    if (chatMessages) {
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }
    
    return msgDiv;
  }
  
  function addRecapMessage(recap: string) {
    if (!recap) return;
    
    const msgDiv = document.createElement('div');
    msgDiv.className = 'message message--recap';
    msgDiv.innerHTML = `
      <div class="message__label">📜 Memoria</div>
      <div class="message__content">${recap.replace(/\n/g, '<br>')}</div>
    `;
    
    if (typingIndicator && chatMessages) {
      chatMessages.insertBefore(msgDiv, typingIndicator);
    } else {
      chatMessages?.appendChild(msgDiv);
    }
  }
  
  // ═══════════════════════════════════════
  // FOCUS (Espansione con Sonnet)
  // ═══════════════════════════════════════
  
  async function handleFocus(messageId: string, originalContent: string) {
    // Trova il messaggio
    const msgDiv = document.querySelector(`[data-message-id="${messageId}"]`);
    if (!msgDiv) return;
    
    const contentDiv = msgDiv.querySelector('.message__content');
    const focusBtn = msgDiv.querySelector('.btn-focus') as HTMLButtonElement;
    
    if (!contentDiv || !focusBtn) return;
    
    // Già espanso?
    if (msgDiv.classList.contains('expanded')) {
      // Toggle back to original
      const original = decodeURIComponent(contentDiv.getAttribute('data-original') || '');
      let displayContent = stripLocationTags(original);
      displayContent = formatTagsForDisplay(displayContent);
      contentDiv.innerHTML = displayContent;
      msgDiv.classList.remove('expanded');
      focusBtn.innerHTML = `
        <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="M21 21l-4.35-4.35"></path>
          <path d="M11 8v6M8 11h6"></path>
        </svg>
        Focus
      `;
      return;
    }
    
    // Mostra loading
    focusBtn.disabled = true;
    focusBtn.innerHTML = `
      <span class="loading-spinner"></span>
      Espando...
    `;
    
    try {
      // Determina il tipo di contesto
      const contextType = detectContextType(originalContent);
      
      const data = await expandMessage(
        originalContent,
        contextType,
        character,
        currentLocationId,
        history.slice(-10)
      );
      
      // Aggiorna contenuto con versione espansa
      let expandedDisplay = stripLocationTags(data.expanded);
      expandedDisplay = formatTagsForDisplay(expandedDisplay);
      contentDiv.innerHTML = expandedDisplay;
      
      // Marca come espanso
      msgDiv.classList.add('expanded');
      focusBtn.innerHTML = `
        <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="M21 21l-4.35-4.35"></path>
          <path d="M8 11h6"></path>
        </svg>
        Riduci
      `;
      
    } catch (error) {
      console.error('Errore espansione:', error);
      focusBtn.innerHTML = `
        <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="M21 21l-4.35-4.35"></path>
          <path d="M11 8v6M8 11h6"></path>
        </svg>
        Focus
      `;
    }
    
    focusBtn.disabled = false;
  }
  
  function detectContextType(content: string): string {
    // Rileva il tipo di contesto per analytics
    if (content.includes('[DMG:') || content.includes('[SPELL:')) return 'combat';
    if (content.includes('[NPC:')) return 'dialogue';
    if (content.includes('[LORE:')) return 'lore';
    if (content.includes('[ITEM:')) return 'discovery';
    return 'description';
  }
  
  function showTyping() {
    typingIndicator?.classList.add('active');
    if (chatMessages) {
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }
  }
  
  function hideTyping() {
    typingIndicator?.classList.remove('active');
  }
  
  async function sendMessage() {
    const text = chatInput?.value.trim();
    if (!text || !character) return;
    
    addMessage(text, true);
    history.push({ role: 'user', content: text });
    saveChat();  // Salva dopo messaggio user
    
    if (chatInput) {
      chatInput.value = '';
      chatInput.style.height = 'auto';
    }
    if (btnSend) btnSend.disabled = true;
    
    showTyping();
    
    try {
      const data = await sendChatMessage(
        text,
        history.slice(-20),
        character,
        currentLocationId
      );
      
      hideTyping();
      
      // Parse tag
      const tags = parseTags(data.response);
      console.log('Tags:', tags);
      console.log('Model:', data.model); // Dovrebbe essere 'haiku'
      
      // Log location updates se presenti
      if (data.location_updates) {
        console.log('Location updates:', data.location_updates);
        
        // Aggiorna mini-mappa se ci sono stati cambiamenti
        if (data.location_updates.locations_created?.length > 0 ||
            data.location_updates.movements?.length > 0 ||
            data.location_updates.modifications?.length > 0) {
          miniMap?.refresh();
        }
        
        // Se c'è stato un movimento, aggiorna location corrente
        if (data.location_updates.movements?.length > 0) {
          const lastMovement = data.location_updates.movements[data.location_updates.movements.length - 1];
          // Supporta sia oggetto {to: "..."} che stringa diretta
          const newLocation = typeof lastMovement === 'string' ? lastMovement : lastMovement.to;
          if (newLocation) {
            await handleLocationChange(currentLocationId, newLocation);
          }
        }
      }
      
      const messageId = `msg-${Date.now()}`;
      addMessage(data.response, false, messageId);
      history.push({ role: 'assistant', content: data.response });
      saveChat();  // Salva dopo messaggio assistant
      
    } catch (error) {
      hideTyping();
      addMessage('*La connessione con il piano astrale si è interrotta momentaneamente...*', false);
      console.error('Error:', error);
    }
    
    if (btnSend) btnSend.disabled = false;
    chatInput?.focus();
  }
  
  async function handleLocationChange(fromLocation: string, toLocation: string) {
    if (!character) return;
    
    try {
      const result = await switchLocation(
        character.id,
        fromLocation,
        toLocation,
        history
      );
      
      // Aggiorna location corrente
      currentLocationId = toLocation;
      
      // Se c'è un recap (non è la prima visita), mostralo
      if (result.recap) {
        addRecapMessage(result.recap);
      }
      
      // Carica la history della nuova location
      if (result.messages && result.messages.length > 0) {
        // Potresti voler caricare i messaggi precedenti
        // Per ora manteniamo solo la storia corrente
        console.log(`Loaded ${result.messages.length} messages from location ${toLocation}`);
      }
      
    } catch (error) {
      console.error('Errore switch location:', error);
    }
  }
  
  // Event listeners
  btnSend?.addEventListener('click', sendMessage);
  
  chatInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });
  
  chatInput?.addEventListener('input', () => {
    if (chatInput) {
      chatInput.style.height = 'auto';
      chatInput.style.height = Math.min(chatInput.scrollHeight, 150) + 'px';
    }
  });
  
  // Init
  init();
</script>

<style>
  .game-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    max-width: 900px;
    margin: 0 auto;
    padding: var(--space-md);
  }
  
  .header-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    margin-right: var(--space-md);
  }
  
  .char-name {
    font-family: var(--font-narrative);
    font-size: 1rem;
    color: var(--parchment);
  }
  
  .char-hp {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--vita);
  }
  
  .btn-sheet {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--shadow);
    border: 1px solid var(--mist);
    border-radius: 6px;
    color: var(--bone);
    font-family: var(--font-ui);
    font-size: 0.9rem;
    text-decoration: none;
    transition: var(--transition-fast);
  }
  
  .btn-sheet:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  
  /* ═══════════════════════════════════════
     MESSAGE HEADER & FOCUS BUTTON
     ═══════════════════════════════════════ */
  
  .message__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xs);
  }
  
  .btn-focus {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    background: transparent;
    border: 1px solid var(--mist);
    border-radius: 4px;
    color: var(--ash);
    font-family: var(--font-ui);
    font-size: 0.7rem;
    cursor: pointer;
    transition: var(--transition-fast);
    opacity: 0;
  }
  
  .message--ai:hover .btn-focus {
    opacity: 1;
  }
  
  .btn-focus:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(201, 169, 89, 0.1);
  }
  
  .btn-focus:disabled {
    opacity: 0.5;
    cursor: wait;
  }
  
  .btn-focus svg {
    flex-shrink: 0;
  }
  
  /* Loading spinner nel pulsante */
  .loading-spinner {
    display: inline-block;
    width: 12px;
    height: 12px;
    border: 2px solid var(--mist);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  
  /* Messaggio espanso */
  .message--ai.expanded {
    border-left: 3px solid var(--accent);
    background: linear-gradient(90deg, rgba(201, 169, 89, 0.05) 0%, transparent 100%);
  }
  
  .message--ai.expanded .btn-focus {
    opacity: 1;
    border-color: var(--accent);
    color: var(--accent);
  }
  
  /* ═══════════════════════════════════════
     RECAP MESSAGE
     ═══════════════════════════════════════ */
  
  .message--recap {
    background: linear-gradient(135deg, rgba(139, 115, 85, 0.15) 0%, rgba(139, 115, 85, 0.05) 100%);
    border: 1px solid rgba(139, 115, 85, 0.3);
    border-radius: 8px;
    padding: var(--space-md);
    margin: var(--space-md) 0;
  }
  
  .message--recap .message__label {
    color: #b8a67d;
    font-family: var(--font-narrative);
    font-size: 0.85rem;
    margin-bottom: var(--space-xs);
  }
  
  .message--recap .message__content {
    color: var(--bone);
    font-style: italic;
    font-size: 0.9rem;
    line-height: 1.6;
  }
</style>
