---
// game.astro - Pagina di gioco principale (chat con GM)
import Layout from '../components/Layout.astro';
import Header from '../components/ui/Header.astro';
import Button from '../components/ui/Button.astro';
import ChatContainer from '../components/chat/ChatContainer.astro';
---

<Layout title="STATISFY RPG - Gioco">
  <div class="game-container">
    <Header showBackButton>
      <div class="header-info">
        <span class="char-name" id="header-name">—</span>
        <span class="char-hp">
          HP: <span id="header-hp">0</span>/<span id="header-hp-max">0</span>
        </span>
      </div>
      <a href="/sheet" class="btn-sheet" id="btn-sheet">
        <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="1.5" fill="none">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
        </svg>
        Scheda
      </a>
    </Header>
    
    <ChatContainer />
  </div>
</Layout>

<script>
  import { parseTags, formatTagsForDisplay } from '../lib/tagParser.js';
  import { sendChatMessage, getCharacterBySlot } from '../lib/api.js';
  
  // State
  let character = null;
  let history = [];
  
  // DOM
  const chatMessages = document.getElementById('chat-messages');
  const chatInput = document.getElementById('chat-input') as HTMLTextAreaElement;
  const btnSend = document.getElementById('btn-send') as HTMLButtonElement;
  const typingIndicator = document.getElementById('typing-indicator');
  
  // Ottieni slot dalla URL
  const urlParams = new URLSearchParams(window.location.search);
  const slot = parseInt(urlParams.get('slot') || '0');
  
  // Salva slot per la pagina sheet
  sessionStorage.setItem('currentSlot', slot.toString());
  
  // Aggiorna link scheda con slot
  const sheetLink = document.getElementById('btn-sheet') as HTMLAnchorElement;
  if (sheetLink) {
    sheetLink.href = `/sheet?slot=${slot}`;
  }
  
  // ═══════════════════════════════════════
  // INIT
  // ═══════════════════════════════════════
  
  async function init() {
    try {
      const result = await getCharacterBySlot(slot);
      
      if (!result.exists) {
        window.location.href = '/';
        return;
      }
      
      character = result.character;
      updateHeaderInfo();
      
    } catch (e) {
      console.error('Errore caricamento personaggio:', e);
      alert('Errore di connessione al server');
      window.location.href = '/';
    }
  }
  
  function updateHeaderInfo() {
    if (!character) return;
    
    document.getElementById('header-name').textContent = character.name;
    document.getElementById('header-hp').textContent = character.hp_current;
    document.getElementById('header-hp-max').textContent = character.hp_max;
  }
  
  // ═══════════════════════════════════════
  // CHAT
  // ═══════════════════════════════════════
  
  function addMessage(content: string, isUser = false) {
    const msgDiv = document.createElement('div');
    msgDiv.className = `message message--${isUser ? 'user' : 'ai'}`;
    
    let displayContent = content;
    if (!isUser) {
      displayContent = formatTagsForDisplay(content);
    }
    
    msgDiv.innerHTML = `
      <div class="message__label">${isUser ? 'Tu' : 'Game Master'}</div>
      <div class="message__content">${displayContent}</div>
    `;
    
    if (typingIndicator && chatMessages) {
      chatMessages.insertBefore(msgDiv, typingIndicator);
    } else {
      chatMessages?.appendChild(msgDiv);
    }
    
    if (chatMessages) {
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }
  }
  
  function showTyping() {
    typingIndicator?.classList.add('active');
    if (chatMessages) {
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }
  }
  
  function hideTyping() {
    typingIndicator?.classList.remove('active');
  }
  
  async function sendMessage() {
    const text = chatInput?.value.trim();
    if (!text || !character) return;
    
    addMessage(text, true);
    history.push({ role: 'user', content: text });
    
    if (chatInput) {
      chatInput.value = '';
      chatInput.style.height = 'auto';
    }
    if (btnSend) btnSend.disabled = true;
    
    showTyping();
    
    try {
      const data = await sendChatMessage(
        text,
        history.slice(-20),
        character
      );
      
      hideTyping();
      
      // Parse tag
      const tags = parseTags(data.response);
      console.log('Tags:', tags);
      
      // TODO: sincronizzare col backend e aggiornare character
      
      addMessage(data.response, false);
      history.push({ role: 'assistant', content: data.response });
      
    } catch (error) {
      hideTyping();
      addMessage('*La connessione con il piano astrale si è interrotta momentaneamente...*', false);
      console.error('Error:', error);
    }
    
    if (btnSend) btnSend.disabled = false;
    chatInput?.focus();
  }
  
  // Event listeners
  btnSend?.addEventListener('click', sendMessage);
  
  chatInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });
  
  chatInput?.addEventListener('input', () => {
    if (chatInput) {
      chatInput.style.height = 'auto';
      chatInput.style.height = Math.min(chatInput.scrollHeight, 150) + 'px';
    }
  });
  
  // Init
  init();
</script>

<style>
  .game-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    max-width: 900px;
    margin: 0 auto;
    padding: var(--space-md);
  }
  
  .header-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    margin-right: var(--space-md);
  }
  
  .char-name {
    font-family: var(--font-narrative);
    font-size: 1rem;
    color: var(--parchment);
  }
  
  .char-hp {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--vita);
  }
  
  .btn-sheet {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--shadow);
    border: 1px solid var(--mist);
    border-radius: 6px;
    color: var(--bone);
    font-family: var(--font-ui);
    font-size: 0.9rem;
    text-decoration: none;
    transition: var(--transition-fast);
  }
  
  .btn-sheet:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
